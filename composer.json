{
    "require": {
        "dompdf/dompdf": "^3.1",
        "phpmailer/phpmailer": "^6.9",
        "phpoffice/phpspreadsheet": "^2.3",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "php-di/php-di": "^7.0",
        "twig/twig": "^3.0",
        "monolog/monolog": "^3.0",
        "ext-pdo": "*"
    },
    "require-dev": {
        "robmorgan/phinx": "^0.16"
    },
    "scripts": {
        "migrate": "phinx migrate",
        "migrate:status": "phinx status",
        "migrate:rollback": "phinx rollback"
    },
    "autoload": {
