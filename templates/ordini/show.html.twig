{% extends 'layout/base.html.twig' %}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/ordini/ordini_list.css">
<link rel="stylesheet" href="/assets/css/views/ordini/ordini_form.css">
<link rel="stylesheet" href="/assets/css/views/offers/offer_show.css">
<link rel="stylesheet" href="/assets/css/views/ordini/ordine_show.css">
{% endblock %}

{% block content %}
{% set s = ordine.status ?? 'bozza' %}
{% set statusLabels = {bozza: 'Bozza', inviato: 'Inviato', accettato: 'Accettato', rifiutato: 'Rifiutato'} %}
{% set ivaPerc = ordine.iva_percentage ?? 22 %}
{% set totaleMerce = ordine.total ?? 0 %}
{% set ivaAmount = (totaleMerce * ivaPerc / 100)|round(2) %}
{% set totaleDoc = totaleMerce + ivaAmount %}

<div class="cos-page">

{# Hero #}
<div class="cos-hero">
  <div class="cos-hero-left">
    <div class="cos-hero-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
    </div>
    <div class="cos-hero-info">
      <div class="cos-hero-row">
        <h1 class="cos-hero-title">Ordine n° {{ ordine.order_number }}</h1>
        <span class="col-badge col-badge-{{ s }}" id="heroBadge">{{ statusLabels[s] ?? s }}</span>
      </div>
      <p class="cos-hero-sub">
        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        {{ ordine.destinatario_name ?? '—' }}
        <span class="cos-hero-sep">·</span>
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {{ ordine.order_date|date('d/m/Y') }}
      </p>
    </div>
  </div>
  <div class="cos-hero-actions">
    <a href="/ordini" class="cos-btn-action">
      <svg viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Lista
    </a>
    <a href="/ordini/{{ ordineId }}/pdf" target="_blank" class="cos-btn-action cos-btn-pdf">
      <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Scarica PDF
    </a>
    <a href="/ordini/{{ ordineId }}/edit" class="cos-btn-edit">
      <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Modifica
    </a>
  </div>
</div>

{% if app.request.get('success') %}
<div class="cof-alert cof-alert-success" style="margin-bottom:16px;">{{ app.request.get('success') }}</div>
{% endif %}

{# Main grid #}
<div class="cos-grid">

  {# ── Left ── #}
  <div class="cos-left">

    {# Status #}
    <div class="cos-card">
      <div class="cos-card-title">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Stato Ordine
      </div>
      <div class="cfo-status-select-group" id="statusSelectGroup" data-ordine-id="{{ ordineId }}">
        {% for val, label in statusLabels %}
        <button type="button"
                class="col-badge col-badge-{{ val }} cof-status-btn {% if s == val %}active{% endif %}"
                data-val="{{ val }}">{{ label }}</button>
        {% endfor %}
      </div>
    </div>

    {# Details #}
    <div class="cos-card">
      <div class="cos-card-title">
        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Dettagli Ordine
      </div>
      <div class="cos-details">
        <div class="cos-detail-row">
          <span class="cos-detail-label">Consorziata</span>
          <span class="cos-detail-value">{{ ordine.destinatario_name ?? '—' }}</span>
        </div>
        <div class="cos-detail-row">
          <span class="cos-detail-label">Cantiere</span>
          <span class="cos-detail-value">{{ ordine.worksite_name ?? '—' }}</span>
        </div>
        <div class="cos-detail-row">
          <span class="cos-detail-label">Numero</span>
          <span class="cos-detail-value">n° {{ ordine.order_number }}</span>
        </div>
        <div class="cos-detail-row">
          <span class="cos-detail-label">Data</span>
          <span class="cos-detail-value">{{ ordine.order_date|date('d/m/Y') }}</span>
        </div>
        {% if ordine.oggetto %}
        <div class="cos-detail-row">
          <span class="cos-detail-label">Oggetto</span>
          <span class="cos-detail-value">{{ ordine.oggetto }}</span>
        </div>
        {% endif %}
        <div class="cos-detail-row">
          <span class="cos-detail-label">Totale Merce</span>
          <span class="cos-detail-value">{{ totaleMerce|number_format(2, ',', '.') }} €</span>
        </div>
        {% if ivaPerc > 0 %}
        <div class="cos-detail-row">
          <span class="cos-detail-label">IVA {{ ivaPerc|number_format(0) }}%</span>
          <span class="cos-detail-value">{{ ivaAmount|number_format(2, ',', '.') }} €</span>
        </div>
        {% endif %}
        <div class="cos-detail-row cos-detail-total">
          <span class="cos-detail-label">Totale Documento</span>
          <span class="cos-detail-value cos-total-value">{{ totaleDoc|number_format(2, ',', '.') }} €</span>
        </div>
      </div>
    </div>

    {# Items summary #}
    {% if items is not empty %}
    <div class="cos-card">
      <div class="cos-card-title">
        <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        Articoli ({{ items|length }})
      </div>
      <div class="cos-items-list">
        {% for item in items %}
        <div class="cos-item-row">
          {% if item.cod_articolo %}
          <span class="cos-item-cod">{{ item.cod_articolo }}</span>
          {% endif %}
          <span class="cos-item-desc">{{ item.descrizione }}</span>
          <span class="cos-item-imp">{{ item.importo|number_format(2, ',', '.') }} €</span>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {# Payment #}
    {% if ordine.termini_pagamento %}
    <div class="cos-card">
      <div class="cos-card-title">
        <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        Pagamento
      </div>
      <p style="font-size:13px;color:#374151;line-height:1.6;white-space:pre-wrap;">{{ ordine.termini_pagamento }}</p>
    </div>
    {% endif %}

    {# Note #}
    {% if ordine.note %}
    <div class="cos-card cos-card-internal">
      <div class="cos-card-title">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        Note
      </div>
      <p class="cos-internal-note">{{ ordine.note }}</p>
    </div>
    {% endif %}

    {# Delete #}
    <div class="cos-card" style="border-color:#fee2e2;background:#fff5f5;">
      <div class="cos-card-title" style="color:#dc2626;">
        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        Elimina Ordine
      </div>
      <p style="font-size:12px;color:#6b7280;margin-bottom:12px;">Questa operazione è irreversibile.</p>
      <button type="button" class="cof-btn-delete" id="deleteOrdineBtn" data-ordine-id="{{ ordineId }}">
        Elimina Ordine n° {{ ordine.order_number }}
      </button>
      <form method="POST" action="/ordini/{{ ordineId }}/delete" id="deleteOrdineForm" style="display:none;"></form>
    </div>

  </div>{# /cos-left #}

  {# ── Right: PDF ── #}
  <div class="cos-right">
    <div class="cos-pdf-wrapper">
      <div class="cos-pdf-toolbar">
        <span class="cos-pdf-label">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Anteprima PDF
        </span>
        <a href="/ordini/{{ ordineId }}/pdf" target="_blank" class="cos-pdf-open">
          <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Apri in nuova scheda
        </a>
      </div>
      <iframe class="cos-pdf-iframe" src="/ordini/{{ ordineId }}/pdf" title="Anteprima PDF"></iframe>
    </div>
  </div>

</div>
</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/ordini/ordine_show.js"></script>
{% endblock %}
