{% extends "layout/base.html.twig" %}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/share/edit_link.css">
{% endblock %}

{% block content %}
{% if successMessage %}
    <div class="intro-y mt-4">
        <div style="background:#dcfce7;color:#15803d;border-radius:10px;padding:12px 18px;font-size:13px;font-weight:600;">
            {{ successMessage }}
        </div>
    </div>
{% endif %}

<div class="cl-page">

    <!-- ── PAGE HEADER ─────────────────────────── -->
    <div class="cl-header">
        <div class="cl-header-left">
            <div class="cl-header-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <div>
                <div class="cl-header-title">Modifica Link</div>
                <div class="cl-header-sub">{{ link.title }}</div>
            </div>
        </div>
        <a href="/share" class="cl-btn-cancel">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Torna alla lista
        </a>
    </div>

    <!-- ── FORM ──────────────────────────────────── -->
    <form id="edit-link-form" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <input type="hidden" name="removed_files" id="removed-files" value="[]">
        <input type="hidden" name="removed_workers" id="removed-workers" value="[]">
        <input type="hidden" name="removed_companies" id="removed-companies" value="[]">

        <div class="cl-layout">

            <!-- ── LEFT: settings ──────────────── -->
            <div>

                <!-- Info base -->
                <div class="cl-card" style="margin-bottom:16px;">
                    <div class="cl-card-header">
                        <div class="cl-card-header-icon" style="background:#ede9fe;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div>
                            <div class="cl-card-header-title">Informazioni link</div>
                            <div class="cl-card-header-sub">Titolo e scadenza</div>
                        </div>
                    </div>
                    <div class="cl-card-body">
                        <div class="cl-field">
                            <label class="cl-label">Titolo *</label>
                            <input type="text" name="title" class="cl-input" value="{{ link.title }}" required>
                        </div>
                        <div class="cl-field">
                            <label class="cl-label">Scadenza</label>
                            <input type="date" name="expires_at" class="cl-input" value="{{ link.expires_at is not empty ? link.expires_at|date('Y-m-d') : '' }}">
                        </div>
                        <div class="cl-field">
                            <label class="cl-label">Password</label>
                            <div style="display:flex;align-items:center;gap:8px;padding:10px 12px;background:#f8fafc;border-radius:9px;border:1.5px solid #e2e8f0;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="{{ link.password is not empty ? '#15803d' : '#94a3b8' }}" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                                <span style="font-size:12px;color:{{ link.password is not empty ? '#15803d' : '#94a3b8' }};font-weight:600;">
                                    {{ link.password is not empty ? 'Protetto da password' : 'Nessuna password' }}
                                </span>
                                <span style="font-size:11px;color:#94a3b8;margin-left:auto;">Non modificabile da qui</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Add new -->
                <div class="cl-card">
                    <div class="cl-card-header">
                        <div class="cl-card-header-icon" style="background:#dbeafe;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        </div>
                        <div>
                            <div class="cl-card-header-title">Aggiungi contenuto</div>
                            <div class="cl-card-header-sub">Tutti i documenti condivisi automaticamente</div>
                        </div>
                    </div>
                    <div class="cl-card-body">
                        <div class="cl-select-buttons">
                            <button type="button" class="cl-select-btn" id="btn-sel-workers"
                                    data-tw-toggle="modal" data-tw-target="#select-workers-modal">
                                <div class="cl-select-btn-icon" style="background:#ede9fe;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                </div>
                                <div>
                                    <div class="cl-select-btn-text">Aggiungi Operai</div>
                                    <div class="cl-select-btn-sub">Tutti i documenti condivisi automaticamente</div>
                                </div>
                                <span class="cl-select-badge" id="workers-badge" style="display:none;"></span>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" style="flex-shrink:0;margin-left:auto;"><path d="M9 18l6-6-6-6"/></svg>
                            </button>

                            <button type="button" class="cl-select-btn" id="btn-sel-companies"
                                    data-tw-toggle="modal" data-tw-target="#select-company-modal">
                                <div class="cl-select-btn-icon" style="background:#dbeafe;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2"><path d="M3 21h18M3 7l9-4 9 4M4 7v14M20 7v14M8 21V11m8 10V11"/></svg>
                                </div>
                                <div>
                                    <div class="cl-select-btn-text">Aggiungi Aziende</div>
                                    <div class="cl-select-btn-sub">Tutti i documenti condivisi automaticamente</div>
                                </div>
                                <span class="cl-select-badge" id="companies-badge" style="display:none;"></span>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" style="flex-shrink:0;margin-left:auto;"><path d="M9 18l6-6-6-6"/></svg>
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── RIGHT: content preview ─────── -->
            <div>
                <div class="cl-card">
                    <div class="cl-card-header">
                        <div class="cl-card-header-icon" style="background:#dcfce7;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#15803d" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        </div>
                        <div>
                            <div class="cl-card-header-title">Contenuto del link</div>
                            <div class="cl-card-header-sub">Tutti i documenti vengono condivisi in tempo reale</div>
                        </div>
                    </div>
                    <div class="cl-card-body">

                        <!-- loader -->
                        <div id="loader" style="display:none;">
                            <div class="cl-loader">
                                <div class="cl-spinner"></div>
                                Caricamento...
                            </div>
                        </div>

                        <!-- Existing workers (association model) -->
                        {% if linkedWorkers is not empty %}
                        <div id="existing-workers-section">
                            <div class="cl-section-title">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                Operai collegati
                            </div>
                            {% for lw in linkedWorkers %}
                            {% set wName = (lw.first_name ~ ' ' ~ lw.last_name)|trim %}
                            {% set wInitials = (lw.first_name[0:1] ~ lw.last_name[0:1])|upper %}
                            <div class="cl-entity-block" id="existing-worker-{{ lw.worker_id }}">
                                <div class="cl-entity-head">
                                    <div class="cl-entity-avatar">{{ wInitials }}</div>
                                    <div style="flex:1;">
                                        <div class="cl-entity-name">{{ wName }}</div>
                                        <div class="cl-entity-company">{{ lw.company ?? '' }}</div>
                                    </div>
                                    <span class="cl-live-badge">
                                        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="5" fill="currentColor"/></svg>
                                        LIVE
                                    </span>
                                    <button type="button" class="cl-entity-remove" data-action="remove-existing-worker" data-worker-id="{{ lw.worker_id }}" title="Rimuovi operaio">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <!-- Existing companies (association model) -->
                        {% if linkedCompanies is not empty %}
                        <div id="existing-companies-section">
                            <div class="cl-section-title">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2.5"><path d="M3 21h18M3 7l9-4 9 4M4 7v14M20 7v14M8 21V11m8 10V11"/></svg>
                                Aziende collegate
                            </div>
                            {% for lc in linkedCompanies %}
                            {% set cInitials = lc.name[0:2]|upper %}
                            <div class="cl-entity-block" id="existing-company-{{ lc.company_id }}">
                                <div class="cl-entity-head">
                                    <div class="cl-entity-avatar" style="background:linear-gradient(135deg,#1d4ed8,#0ea5e9);">{{ cInitials }}</div>
                                    <div style="flex:1;">
                                        <div class="cl-entity-name">{{ lc.name }}</div>
                                    </div>
                                    <span class="cl-live-badge">
                                        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="5" fill="currentColor"/></svg>
                                        LIVE
                                    </span>
                                    <button type="button" class="cl-entity-remove" data-action="remove-existing-company" data-company-id="{{ lc.company_id }}" title="Rimuovi azienda">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <!-- Existing manual files -->
                        {% if manualFiles is not empty %}
                        <div id="existing-manual-section">
                            <div class="cl-section-title">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                Documenti caricati manualmente
                            </div>
                            {% for mf in manualFiles %}
                            <div class="cl-doc-row" id="existing-file-{{ mf.id }}" style="background:#f8fafc;border:1.5px solid #e8edf3;border-radius:8px;margin-bottom:6px;">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                <span style="font-weight:600;">{{ mf.original_name }}</span>
                                {% if mf.company_name is not empty %}
                                    <span style="font-size:11px;color:#94a3b8;">({{ mf.company_name }})</span>
                                {% endif %}
                                <button type="button" class="cl-doc-remove" data-action="remove-existing-file" data-file-id="{{ mf.id }}" style="margin-left:auto;" title="Rimuovi">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <!-- New workers (populated by JS) -->
                        <div id="documents-section" style="display:none;">
                            <div class="cl-section-title">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                Nuovi Operai
                            </div>
                            <div id="workers-documents"></div>
                        </div>

                        <!-- New companies (populated by JS) -->
                        <div id="company-documents-section" style="display:none;">
                            <div class="cl-section-title">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2.5"><path d="M3 21h18M3 7l9-4 9 4M4 7v14M20 7v14M8 21V11m8 10V11"/></svg>
                                Nuove Aziende
                            </div>
                            <div id="company-documents"></div>
                        </div>

                        <!-- manual docs add -->
                        <div id="manual-docs-section" style="margin-top:20px;">
                            <div class="cl-section-title">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                Carica nuovi documenti
                            </div>
                            <div id="manual-rows"></div>
                            <button type="button" class="cl-add-doc-btn" data-action="add-manual-doc">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Aggiungi documento
                            </button>
                        </div>

                        <!-- progress -->
                        <div id="upload-progress-wrapper" style="display:none;margin-top:16px;">
                            <div class="cl-progress-wrap">
                                <div class="cl-progress-label" id="upload-progress-label">Caricamento: 0%</div>
                                <div class="cl-progress-track">
                                    <div id="upload-progress-bar" class="cl-progress-fill"></div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="cl-submit-bar">
                    <input type="hidden" name="workers"   id="workers-hidden">
                    <input type="hidden" name="companies" id="companies-hidden">
                    <a href="/share" class="cl-btn-cancel">Annulla</a>
                    <button id="edit-link-submit" type="submit" class="cl-btn-submit">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Salva Modifiche
                    </button>
                </div>

            </div>
        </div>
    </form>
</div>

<!-- ── WORKERS MODAL ─────────────────────────── -->
<div id="select-workers-modal" class="modal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="font-medium text-lg">Seleziona Operai</h2>
                <button type="button" class="btn-close" data-tw-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="search-workers" class="form-control mb-4" placeholder="Cerca lavoratore...">
                <div class="overflow-auto" style="max-height:450px;">
                    <table class="table table-report w-full">
                        <thead><tr>
                            <th class="w-10 text-center"><input type="checkbox" id="select-all-workers"></th>
                            <th>Nome</th>
                        </tr></thead>
                        <tbody id="workers-list">
                        {% for w in workers %}
                            <tr>
                                <td class="text-center"><input type="checkbox" value="{{ w.id }}" class="worker-checkbox"></td>
                                <td>
                                    {{ w.nome }}
                                    <span class="text-xs text-slate-500 block">{{ w.company }}</span>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-tw-dismiss="modal">Chiudi</button>
                <button type="button" class="btn btn-primary" id="confirm-workers">Conferma</button>
            </div>
        </div>
    </div>
</div>

<!-- ── COMPANIES MODAL ───────────────────────── -->
<div id="select-company-modal" class="modal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="font-medium text-lg">Seleziona Aziende</h2>
                <button class="btn-close" data-tw-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="search-company" class="form-control mb-4" placeholder="Cerca azienda...">
                <div class="overflow-auto" style="max-height:450px;">
                    <table class="table table-report w-full">
                        <thead><tr>
                            <th class="w-10 text-center"><input type="checkbox" id="select-all-companies"></th>
                            <th>Azienda</th>
                        </tr></thead>
                        <tbody id="company-list">
                        {% for c in companies %}
                            <tr>
                                <td class="text-center"><input type="checkbox" value="{{ c.id }}" class="company-checkbox"></td>
                                <td>{{ c.name }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-tw-dismiss="modal">Chiudi</button>
                <button class="btn btn-primary" id="confirm-company">Conferma</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/share/edit_link.js"></script>
{% endblock %}
