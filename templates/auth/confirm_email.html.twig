<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8">
    <link href="{{ appUrl }}/includes/template/dist/images/logo.png" rel="shortcut icon">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="BOB">
    <title>{{ pageTitle }} - BOB</title>
    <link rel="stylesheet" href="{{ appUrl }}/includes/template/dist/css/app.css" />
</head>
<body class="login">
<div class="container sm:px-10">
    <div class="block xl:grid grid-cols-2 gap-4">

        <!-- LEFT BRAND PANEL -->
        <div class="hidden xl:flex flex-col min-h-screen">
            <a href="#" class="-intro-x flex items-center pt-5">
                <img alt="Bob logo" class="w-8" src="{{ appUrl }}/includes/template/dist/images/logo.png">
                <span class="text-white text-xl ml-3"> BOB</span>
            </a>
            <div class="my-auto">
                <img alt="" class="-intro-x w-2/3 -mt-36" src="/includes/template/dist/images/csmontaggi_logo.png">
            </div>
        </div>

        <!-- RIGHT CONFIRM CARD -->
        <div class="h-screen xl:h-auto flex py-5 xl:py-0 my-10 xl:my-0">
            <div class="my-auto mx-auto xl:ml-20 bg-white dark:bg-darkmode-600 xl:bg-transparent
                       px-5 sm:px-8 py-8 xl:p-0 rounded-md shadow-md xl:shadow-none
                       w-full sm:w-3/4 lg:w-2/4 xl:w-auto">

                <div class="intro-y box p-5 mt-5">
                    <h2 class="text-lg font-medium mb-4">{{ pageTitle }}</h2>

                    {% if success is defined %}
                        <div class="alert alert-success mb-4">{{ success }}</div>
                        <p><a href="/login" class="btn btn-primary">Go to Login</a></p>
                    {% elseif error is defined %}
                        <div class="alert alert-danger mb-4">{{ error }}</div>
                    {% endif %}
                </div>

            </div>
        </div>

    </div>
</div>
<script src="{{ appUrl }}/includes/template/dist/js/app.js"></script>
</body>
</html>
