<!DOCTYPE html>
<html lang="it" class="light">
<head>
    <meta charset="utf-8">
    <title>Cambia Password - BOB</title>
    <link rel="stylesheet" href="/includes/template/dist/css/app.css">
</head>
<body class="login">
<div class="container sm:px-10">
    <div class="block xl:grid grid-cols-2 gap-4">

        <!-- LEFT -->
        <div class="hidden xl:flex flex-col min-h-screen">
            <a class="-intro-x flex items-center pt-5">
                <img class="w-8" src="/includes/template/dist/images/logo.png">
                <span class="text-white text-xl ml-3"> BOB</span>
            </a>
            <div class="my-auto">
                <img class="-intro-x w-2/3 -mt-36" src="/includes/template/dist/images/csmontaggi_logo.png" alt="CS Montaggi">
            </div>
        </div>

        <!-- FORM -->
        <div class="h-screen xl:h-auto flex py-5 my-10">
            <div class="my-auto mx-auto bg-white dark:bg-darkmode-600 px-8 py-8 rounded-md shadow-md w-full sm:w-3/4 lg:w-2/4">

                <h2 class="font-bold text-2xl text-center mb-2">Imposta una nuova password</h2>
                <p class="text-slate-500 text-center mb-6">E' obbligatorio cambiare la password al primo accesso</p>

                {% if error %}
                    <div class="alert alert-danger-soft mb-4">{{ error }}</div>
                {% endif %}

                <form method="POST">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

                    <input type="password" id="password" name="password"
                           class="form-control py-3 px-4 block mb-2"
                           placeholder="Nuova password" required>

                    <div class="w-full h-2 bg-slate-200 rounded overflow-hidden">
                        <div id="pwd-bar" class="h-full transition-all"></div>
                    </div>
                    <p id="pwd-text" class="text-xs text-slate-500 mb-4"></p>

                    <input type="password" name="confirm_password"
                           class="form-control py-3 px-4 block mb-6"
                           placeholder="Conferma password" required>

                    <button class="btn btn-primary w-full py-3">Salva password</button>
                </form>
            </div>
        </div>

    </div>
</div>
<script src="/assets/js/views/auth/change_password.js"></script>
<script src="/includes/template/dist/js/app.js"></script>
</body>
</html>
