{% extends 'layout/base.html.twig' %}

{# Data provided by UsersController::createBobUser()
   Variables: companies (array of {id, name}), success, error, tempPassword,
              post (array of submitted POST values for re-populating on error)
   TODO: controller must move POST handling, DB inserts, Mailer call,
         and duplicate-check queries out of the old view into this action,
         then pass the above variables to this template. #}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/users/create_user.css">
{% endblock %}

{% block content %}
<div class="cu-page">

    <!-- HERO -->
    <div class="cu-hero">
        <div class="cu-hero-top">
            <div class="cu-hero-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
            </div>
            <div>
                <div class="cu-hero-title">Nuovo Utente BOB</div>
                <div class="cu-hero-sub">Crea un account di accesso al sistema</div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    {% if success %}
        <div class="cu-alert cu-alert-ok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div>
                {{ success }}
                {% if tempPassword %}
                    <div class="cu-pw-box">
                        <span id="pw-display">{{ tempPassword }}</span>
                        <button type="button" class="cu-pw-copy" onclick="navigator.clipboard.writeText(document.getElementById('pw-display').textContent).then(()=>this.textContent='Copiato!')">Copia</button>
                    </div>
                    <div style="font-size:11px; color:#64748b; margin-top:6px; font-weight:400;">
                        L'utente dovrà cambiare la password al primo accesso.
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {% if error %}
        <div class="cu-alert cu-alert-err">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            {{ error }}
        </div>
    {% endif %}

    <form method="POST" action="" autocomplete="off">

        <!-- Section: Identity -->
        <div class="cu-card">
            <div class="cu-card-header">
                <div class="cu-card-icon" style="background:#eff6ff; color:#1d4ed8;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="cu-card-title">Dati Personali</div>
            </div>
            <div class="cu-card-body">
                <div class="cu-row">
                    <div class="cu-field">
                        <label for="first_name">Nome *</label>
                        <input type="text" id="first_name" name="first_name" required
                               value="{{ post.first_name ?? '' }}">
                    </div>
                    <div class="cu-field">
                        <label for="last_name">Cognome *</label>
                        <input type="text" id="last_name" name="last_name" required
                               value="{{ post.last_name ?? '' }}">
                    </div>
                </div>
                <div class="cu-row">
                    <div class="cu-field">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" required
                               value="{{ post.email ?? '' }}">
                    </div>
                    <div class="cu-field">
                        <label for="phone">Telefono</label>
                        <input type="text" id="phone" name="phone"
                               value="{{ post.phone ?? '' }}">
                    </div>
                </div>
            </div>
        </div>

        <!-- Section: Account -->
        <div class="cu-card">
            <div class="cu-card-header">
                <div class="cu-card-icon" style="background:#f0fdf4; color:#15803d;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                </div>
                <div class="cu-card-title">Account</div>
            </div>
            <div class="cu-card-body">
                <div class="cu-row">
                    <div class="cu-field">
                        <label for="username">Username *</label>
                        <input type="text" id="username" name="username" required autocomplete="off"
                               value="{{ post.username ?? '' }}">
                    </div>
                    <div class="cu-field">
                        <label for="type">Tipo Utente</label>
                        <select id="type" name="type">
                            <option value="user"{{ (post.type ?? 'user') == 'user' ? ' selected' : '' }}>User (interno)</option>
                            <option value="worker"{{ (post.type ?? '') == 'worker' ? ' selected' : '' }}>Worker</option>
                            <option value="client"{{ (post.type ?? '') == 'client' ? ' selected' : '' }}>Client</option>
                        </select>
                    </div>
                </div>
                <div class="cu-row">
                    <div class="cu-field">
                        <label for="access_profile">Profilo Accesso</label>
                        <select id="access_profile" name="access_profile">
                            <option value="INTERNAL"{{ (post.access_profile ?? 'INTERNAL') == 'INTERNAL' ? ' selected' : '' }}>Internal</option>
                            <option value="COMPANY"{{ (post.access_profile ?? '') == 'COMPANY' ? ' selected' : '' }}>Company</option>
                            <option value="CLIENT"{{ (post.access_profile ?? '') == 'CLIENT' ? ' selected' : '' }}>Client</option>
                            <option value="WORKER"{{ (post.access_profile ?? '') == 'WORKER' ? ' selected' : '' }}>Worker</option>
                        </select>
                    </div>
                    <div class="cu-field">
                        <label for="company_id">Azienda</label>
                        <select id="company_id" name="company_id">
                            <option value="">— Nessuna —</option>
                            {% for co in companies %}
                                <option value="{{ co.id }}"{{ (post.company_id ?? 0)|number_format == co.id ? ' selected' : '' }}>
                                    {{ co.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="cu-row single">
                    <div class="cu-field">
                        <label for="role">Ruolo</label>
                        <input type="text" id="role" name="role" placeholder="es. admin, user, company_viewer"
                               value="{{ post.role ?? 'user' }}">
                    </div>
                </div>

                <div class="cu-alert cu-alert-info" style="margin-top:4px; margin-bottom:0;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0; margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    La password viene generata automaticamente. L'utente dovrà cambiarla al primo accesso.
                </div>
            </div>
        </div>

        <!-- Section: Options -->
        <div class="cu-card">
            <div class="cu-card-body" style="padding: 16px 24px;">
                <div class="cu-check">
                    <input type="checkbox" id="send_email" name="send_email" value="1" checked>
                    <label for="send_email">Invia email con credenziali di accesso</label>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="cu-actions">
            <button type="submit" class="cu-btn-submit">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                Crea Utente
            </button>
            <a href="/users/permissions" class="cu-btn-back">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Gestione Permessi
            </a>
        </div>

    </form>
</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/users/create_user.js"></script>
{% endblock %}
