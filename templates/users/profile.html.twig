{% extends 'layout/base.html.twig' %}

{# Data provided by UsersController::profile()
   Variables: userData, fullName, initials, photo, hasPhoto,
              roleLabel, memberSince,
              profileMsg, profileErr, pwdMsg, pwdErr
   TODO: controller must move POST handling, DB queries, photo upload logic,
         and password verification out of the old view into this action,
         then pass the above variables to this template. #}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/users/profile.css">
{% endblock %}

{% block content %}
<div class="pr-page">

    <!-- HERO -->
    <div class="pr-hero">
        <div class="pr-hero-avatar">
            {% if hasPhoto %}
                <img src="{{ photo }}" alt="{{ fullName }}">
            {% else %}
                {{ initials }}
            {% endif %}
        </div>
        <div class="pr-hero-info">
            <h1 class="pr-hero-name">{{ fullName }}</h1>
            <div class="pr-hero-meta">
                {% if userData.role != 'company_viewer' %}
                <span class="pr-hero-tag">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                    {{ roleLabel }}
                </span>
                {% endif %}
                {% if userData.company_name is not empty %}
                <span class="pr-hero-tag">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    {{ userData.company_name }}
                </span>
                {% endif %}
                {% if memberSince %}
                <span class="pr-hero-tag">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Dal {{ memberSince }}
                </span>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- PROFILE INFO -->
    <div class="pr-section">
        <div class="pr-section-head">
            <div class="pr-section-icon" style="background:#eff6ff;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
                <h3 class="pr-section-title">Informazioni Personali</h3>
                <p class="pr-section-sub">Aggiorna i tuoi dati</p>
            </div>
        </div>
        <div class="pr-section-body">
            {% if profileMsg %}
                <div class="pr-toast pr-toast-ok">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    {{ profileMsg }}
                </div>
            {% endif %}
            {% if profileErr %}
                <div class="pr-toast pr-toast-err">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    {{ profileErr }}
                </div>
            {% endif %}

            <form method="POST">
                <input type="hidden" name="action" value="profile">
                <div class="pr-form-grid">
                    <div class="pr-field">
                        <label class="pr-label">Nome</label>
                        <input type="text" name="first_name" class="pr-input" value="{{ userData.first_name }}" required>
                    </div>
                    <div class="pr-field">
                        <label class="pr-label">Cognome</label>
                        <input type="text" name="last_name" class="pr-input" value="{{ userData.last_name }}" required>
                    </div>
                    <div class="pr-field">
                        <label class="pr-label">Email</label>
                        {% if userData.role == 'company_viewer' %}
                            <input type="email" class="pr-input" value="{{ userData.email }}" readonly>
                        {% else %}
                            <input type="email" name="email" class="pr-input" value="{{ userData.email }}">
                        {% endif %}
                    </div>
                    <div class="pr-field">
                        <label class="pr-label">Telefono</label>
                        <input type="text" name="phone" class="pr-input" value="{{ userData.phone }}">
                    </div>
                    <div class="pr-field">
                        <label class="pr-label">Username</label>
                        <input type="text" class="pr-input" value="{{ userData.username }}" readonly>
                    </div>
                    {% if userData.role != 'company_viewer' %}
                    <div class="pr-field">
                        <label class="pr-label">Ruolo</label>
                        <input type="text" class="pr-input" value="{{ roleLabel }}" readonly>
                    </div>
                    {% endif %}
                </div>
                <div style="margin-top:20px;display:flex;justify-content:flex-end;">
                    <button type="submit" class="pr-btn pr-btn-primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Salva Modifiche
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- PHOTO -->
    <div class="pr-section">
        <div class="pr-section-head">
            <div class="pr-section-icon" style="background:#faf5ff;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
            <div>
                <h3 class="pr-section-title">Foto Profilo</h3>
                <p class="pr-section-sub">Cambia la tua immagine</p>
            </div>
        </div>
        <div class="pr-section-body">
            <form method="POST" enctype="multipart/form-data">
                <input type="hidden" name="action" value="photo">
                <div class="pr-photo-wrap">
                    <div class="pr-photo-preview" id="photo-preview">
                        {% if hasPhoto %}
                            <img src="{{ photo }}" alt="Foto">
                        {% else %}
                            {{ initials }}
                        {% endif %}
                    </div>
                    <div>
                        <label class="pr-btn pr-btn-outline" style="cursor:pointer;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            Scegli immagine
                            <input type="file" name="photo" accept="image/jpeg,image/png,image/webp" style="display:none;" id="photo-input">
                        </label>
                        <button type="submit" class="pr-btn pr-btn-primary" id="photo-submit" style="display:none;margin-left:8px;">
                            Carica
                        </button>
                        <div class="pr-photo-hint">JPG, PNG o WebP. Max 5 MB.</div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- PASSWORD -->
    <div class="pr-section" id="password">
        <div class="pr-section-head">
            <div class="pr-section-icon" style="background:#fef3c7;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </div>
            <div>
                <h3 class="pr-section-title">Cambia Password</h3>
                <p class="pr-section-sub">Aggiorna la tua password di accesso</p>
            </div>
        </div>
        <div class="pr-section-body">
            {% if pwdMsg %}
                <div class="pr-toast pr-toast-ok">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    {{ pwdMsg }}
                </div>
            {% endif %}
            {% if pwdErr %}
                <div class="pr-toast pr-toast-err">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    {{ pwdErr }}
                </div>
            {% endif %}

            <form method="POST">
                <input type="hidden" name="action" value="password">
                <div style="display:flex;flex-direction:column;gap:16px;max-width:400px;">
                    <div class="pr-field">
                        <label class="pr-label">Password Attuale</label>
                        <input type="password" name="current_password" class="pr-input" required>
                    </div>
                    <div class="pr-field">
                        <label class="pr-label">Nuova Password</label>
                        <input type="password" name="new_password" class="pr-input" id="new-pwd" required>
                        <div class="pr-pwd-bar-bg"><div class="pr-pwd-bar-fill" id="pwd-bar"></div></div>
                        <div class="pr-pwd-text" id="pwd-text"></div>
                    </div>
                    <div class="pr-field">
                        <label class="pr-label">Conferma Nuova Password</label>
                        <input type="password" name="confirm_password" class="pr-input" required>
                    </div>
                    <div>
                        <button type="submit" class="pr-btn pr-btn-primary">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                            Aggiorna Password
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/users/profile.js"></script>
{% endblock %}
