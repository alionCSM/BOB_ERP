{% extends 'layout/base.html.twig' %}

{% block head %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css">
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
<link rel="stylesheet" href="/assets/css/views/users/edit.css">
{% endblock %}

{% block content %}
{% set photoSrc = workerData.photo is not empty ? '/users/' ~ workerData.id ~ '/worker-photo?uid=' ~ workerData.uid : '/uploads/avatar.jpg' %}

<div class="ue-page">
    {% if not isExternalLimitedUi %}
    <div class="ue-page-header">
        <div class="ue-search-top">
            <select id="worker-search" placeholder="Cerca operaio..."></select>
        </div>
    </div>
    {% endif %}
    <div class="ue-layout">
        <!-- ── Sidebar ── -->
        <div class="ue-sidebar">
            <div class="ue-sidebar-top">
                <div class="ue-photo-wrap" onclick="openImageModal('{{ photoSrc }}', '{{ (workerData.first_name ~ ' ' ~ workerData.last_name)|e('js') }}')" title="Clicca per ingrandire">
                    <img id="profile-preview" src="{{ photoSrc }}" alt="Profile">
                    <div class="ue-photo-overlay">
                        <svg width="22" height="22" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="3"/><path d="M3 11a8 8 0 1116 0 8 8 0 01-16 0z"/></svg>
                    </div>
                </div>
                <p class="ue-sidebar-name">{{ workerData.first_name }} {{ workerData.last_name }}</p>
                <p class="ue-sidebar-company">{{ workerData.company }}</p>
                {% if workerData.active == 'Y' %}
                    <span class="ue-status-badge ue-status-active">
                        <svg width="8" height="8"><circle cx="4" cy="4" r="4" fill="#22c55e"/></svg> Attivo
                    </span>
                {% else %}
                    <span class="ue-status-badge ue-status-inactive">
                        <svg width="8" height="8"><circle cx="4" cy="4" r="4" fill="#ef4444"/></svg> Inattivo
                    </span>
                {% endif %}
                <!-- Photo upload form -->
                <form method="POST" action="/users/{{ workerId }}/photo" enctype="multipart/form-data" style="display:flex; gap:6px; margin-top:14px; padding:0 10px;">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="uid" value="{{ workerData.uid }}">
                    <label class="ue-btn-photo-hero" style="cursor:pointer;">
                        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="vertical-align:-2px; margin-right:3px;"><path d="M6.5 1v11M1 6.5h11"/></svg>
                        Cambia
                        <input type="file" name="profile_photo" id="profile-photo" style="display:none;" accept="image/*">
                    </label>
                    <button type="submit" class="ue-btn-photo-hero ue-btn-photo-hero-save">Aggiorna</button>
                </form>
            </div>

            <div class="ue-sidebar-body">
                <!-- Toggle active/inactive -->
                <form method="POST" action="/users/{{ workerId }}/toggle">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="uid" value="{{ workerData.uid }}">
                    {% if workerData.active == 'Y' %}
                        <input type="hidden" name="new_status" value="N">
                        <button type="submit" class="ue-btn-toggle ue-btn-danger">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 3L3 13M3 3l10 10"/></svg>
                            Disattiva Operaio
                        </button>
                    {% else %}
                        <input type="hidden" name="new_status" value="Y">
                        <button type="submit" class="ue-btn-toggle ue-btn-success">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8.5l3.5 3.5L13 5"/></svg>
                            Riattiva Operaio
                        </button>
                    {% endif %}
                </form>

                {% if tempPassword is not empty %}
                    <div class="ue-temp-pass" style="margin-top:12px;">
                        <p class="ue-temp-pass-label">Password temporanea</p>
                        <p class="ue-temp-pass-value">{{ tempPassword }}</p>
                        <p class="ue-temp-pass-hint">Mostrata una sola volta</p>
                    </div>
                {% endif %}

                {% if not isExternalLimitedUi and canCreateUser %}
                    <form method="POST" action="/users/{{ workerId }}/account" style="margin-top:12px;">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <input type="hidden" name="uid" value="{{ workerData.uid }}">
                        <button type="submit" class="ue-btn-create">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 3v10M3 8h10"/></svg>
                            Crea accesso BOB
                        </button>
                        <p style="font-size:10px; color:#94a3b8; text-align:center; margin:6px 0 0;">
                            Password generata automaticamente
                        </p>
                    </form>
                {% elseif workerUser %}
                    <div class="ue-access-info" style="margin-top:12px;">
                        <div class="ue-access-info-icon"><svg width="20" height="20" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round"><path d="M5 10l3.5 3.5L15 7"/></svg></div>
                        <p class="ue-access-info-label">Accesso già creato</p>
                        <p class="ue-access-info-email">{{ workerUser.email }}</p>
                    </div>
                {% elseif not isExternalLimitedUi %}
                    <div class="ue-access-warn" style="margin-top:12px;">
                        <div class="ue-access-warn-icon"><svg width="20" height="20" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round"><path d="M10 6v4m0 3h.01M3.5 16.5h13L10 3.5z"/></svg></div>
                        <p style="font-size:12px; font-weight:600; color:#1e293b; margin:6px 0 2px;">Impossibile creare accesso</p>
                        <p style="font-size:11px; color:#94a3b8;">Operaio non attivo o email mancante</p>
                    </div>
                {% endif %}
            </div>

            <!-- Tab navigation -->
            <div class="ue-tabs">
                <a href="#" class="ue-tab tab-link active" data-tab="personal-info">
                    <svg class="ue-tab-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 12a4 4 0 10-8 0 4 4 0 008 0zM2 17c0-2.2 1.8-4 4-4h6c2.2 0 4 1.8 4 4"/></svg>
                    Info Personali
                </a>
                <a href="#" class="ue-tab tab-link" data-tab="company-info">
                    <svg class="ue-tab-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l7-7 7 7v8a1 1 0 01-1 1H4a1 1 0 01-1-1V9z"/><path d="M9 18V12h4v6"/></svg>
                    Cambia Azienda
                </a>
                <a href="#" class="ue-tab tab-link" data-tab="documents">
                    <svg class="ue-tab-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V6z"/><path d="M14 2v4h4M10 12H8m6 4H8"/></svg>
                    Documenti
                </a>
                {% if not isExternalLimitedUi %}
                    <a href="#" class="ue-tab tab-link" data-tab="personal-documents">
                        <svg class="ue-tab-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V6z"/><path d="M14 2v4h4M10 10l-2 2 2 2m2-4l2 2-2 2"/></svg>
                        Doc. Personali
                    </a>
                    <a href="#" class="ue-tab tab-link" data-tab="presenze">
                        <svg class="ue-tab-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="14" height="14" rx="2"/><path d="M3 8h14M7 2v4m6-4v4"/></svg>
                        Presenze
                    </a>
                    <a href="#" class="ue-tab tab-link" data-tab="ferie">
                        <svg class="ue-tab-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="10" cy="10" r="8"/><path d="M10 6v4l2.5 2.5"/></svg>
                        Ferie/Permessi
                    </a>
                {% endif %}
                <a href="#" class="ue-tab tab-link" data-tab="archivio">
                    <svg class="ue-tab-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4h16v4H2zM4 8v8a2 2 0 002 2h8a2 2 0 002-2V8"/><path d="M8 12h4"/></svg>
                    Archivio
                </a>
            </div>

            <a href="{{ isExternalLimitedUi ? '/users/workers' : '/users' }}" class="ue-sidebar-back">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 7H3m0 0l3-3M3 7l3 3"/></svg>
                Torna alla lista
            </a>
        </div>

        <!-- ── Main Content ── -->
        <div>
            <!-- Personal Info -->
            <form method="POST" action="/users/{{ workerId }}/update" class="needs-validation">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <input type="hidden" name="uid" value="{{ workerData.uid }}">
                <div id="personal-info" class="tab-content active">
                    <div class="ue-card">
                        <div class="ue-card-header">
                            <div class="ue-card-header-icon" style="background:#f5f3ff; color:#7c3aed;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 12a4 4 0 10-8 0 4 4 0 008 0zM2 17c0-2.2 1.8-4 4-4h6c2.2 0 4 1.8 4 4"/></svg>
                            </div>
                            <div>
                                <div class="ue-card-header-title">Informazioni Personali</div>
                                <div class="ue-card-header-sub">Anagrafica e contatti dell'operaio</div>
                            </div>
                        </div>
                        <div class="ue-card-body">
                            <div class="ue-grid">
                                <div class="ue-field">
                                    <label class="ue-label">Nome</label>
                                    <input name="first_name" type="text" class="ue-input" value="{{ workerData.first_name }}" required>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Cognome</label>
                                    <input name="last_name" type="text" class="ue-input" value="{{ workerData.last_name }}" required>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Data di nascita</label>
                                    <input name="birthday" type="date" class="ue-input" value="{{ workerData.birthday }}" required>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Luogo di nascita</label>
                                    <input name="birthplace" type="text" class="ue-input" value="{{ workerData.city_of_birth }}" required>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Email</label>
                                    <input name="email" type="email" class="ue-input" value="{{ workerData.email }}">
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Telefono</label>
                                    <input name="phone" type="text" class="ue-input" value="{{ workerData.phone }}">
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Azienda</label>
                                    <input type="text" class="ue-input" value="{{ workerData.company }}" disabled style="background:#f8fafc;color:#64748b;cursor:not-allowed;">
                                    <input type="hidden" name="company" value="{{ workerData.company }}">
                                    <span style="font-size:11px;color:#94a3b8;margin-top:2px;">Usa "Cambia Azienda" per modificare</span>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Tipo Operaio</label>
                                    <select name="type_worker" class="ue-input" required>
                                        <option value="OPERAIO"{{ workerData.type_worker == 'OPERAIO' ? ' selected' : '' }}>OPERAIO</option>
                                        <option value="PREPOSTO"{{ workerData.type_worker == 'PREPOSTO' ? ' selected' : '' }}>PREPOSTO</option>
                                        <option value="LEGALE RAPPRESENTANTE"{{ workerData.type_worker == 'LEGALE RAPPRESENTANTE' ? ' selected' : '' }}>LEGALE RAPPRESENTANTE</option>
                                    </select>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Data Assunzione</label>
                                    <input type="date" name="active_from" class="ue-input" value="{{ workerData.active_from }}">
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Codice Fiscale</label>
                                    <input name="fiscal_code" type="text" class="ue-input" style="text-transform:uppercase;" value="{{ workerData.fiscal_code|upper }}" required>
                                </div>
                            </div>
                            <div style="display:flex; justify-content:flex-end; margin-top:24px;">
                                <button type="submit" class="ue-btn-submit">Salva Modifiche</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <!-- Company Change -->
            <form method="POST" action="/users/{{ workerId }}/company" class="needs-validation">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <input type="hidden" name="uid" value="{{ workerData.uid }}">
                <div id="company-info" class="tab-content hidden">
                    <div class="ue-card">
                        <div class="ue-card-header">
                            <div class="ue-card-header-icon" style="background:#fff7ed; color:#ea580c;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l7-7 7 7v8a1 1 0 01-1 1H4a1 1 0 01-1-1V9z"/><path d="M9 18V12h4v6"/></svg>
                            </div>
                            <div>
                                <div class="ue-card-header-title">Cambio Azienda</div>
                                <div class="ue-card-header-sub">Trasferisci l'operaio ad una nuova azienda</div>
                            </div>
                        </div>
                        <div class="ue-card-body">
                            <div style="background:#fff7ed; border:1.5px solid #fed7aa; border-radius:10px; padding:14px 16px; margin-bottom:20px; display:flex; align-items:flex-start; gap:10px;">
                                <svg width="18" height="18" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" style="margin-top:1px; flex-shrink:0;"><path d="M9 6v3m0 3h.01M3.5 15.5h11L9 3.5z"/></svg>
                                <p style="font-size:12px; color:#9a3412; margin:0;">Questa operazione creerà un record nello storico aziende. L'azienda attuale verrà archiviata.</p>
                            </div>
                            <div class="ue-grid">
                                <div class="ue-field">
                                    <label class="ue-label">Nuova Azienda</label>
                                    {% if isExternalLimitedUi %}
                                        <select name="company" class="ue-input" required>
                                            <option value="">Seleziona azienda</option>
                                            {% for companyName in allowedCompanyNames %}
                                                <option value="{{ companyName }}">{{ companyName }}</option>
                                            {% endfor %}
                                        </select>
                                    {% else %}
                                        <input name="company" type="text" class="ue-input" required>
                                    {% endif %}
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Ruolo</label>
                                    <select name="role" class="ue-input" required>
                                        <option value="OPERAIO">OPERAIO</option>
                                        <option value="PREPOSTO">PREPOSTO</option>
                                        <option value="LEGALE RAPPRESENTANTE">LEGALE RAPPRESENTANTE</option>
                                    </select>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Data Inizio Nuova Azienda</label>
                                    <input name="start_date" type="date" class="ue-input" required>
                                </div>
                                <div class="ue-field">
                                    <label class="ue-label">Ultimo Giorno Azienda Attuale</label>
                                    <input name="end_date" type="date" class="ue-input">
                                    <span class="ue-hint">Lascia vuoto per usare il giorno prima dell'inizio</span>
                                </div>
                            </div>
                            <div style="display:flex; justify-content:flex-end; margin-top:24px;">
                                <button type="submit" class="ue-btn-submit" style="background:linear-gradient(135deg,#9a3412,#ea580c);">Cambia Azienda</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <!-- Document Tabs -->
            <div id="documents" class="tab-content hidden">
                <div class="ue-card">
                    <div class="ue-card-header">
                        <div class="ue-card-header-icon" style="background:#eff6ff; color:#2563eb;">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V6z"/><path d="M14 2v4h4M10 12H8m6 4H8"/></svg>
                        </div>
                        <div>
                            <div class="ue-card-header-title">Documenti Aziendali</div>
                            <div class="ue-card-header-sub">Gestisci i documenti associati a questo operaio</div>
                        </div>
                    </div>
                    <div class="ue-card-body ue-doc-content">
                        {# TODO: include documents/documenti_aziendali sub-template #}
                        {{ documentiAziendali|raw }}
                    </div>
                </div>
            </div>
            {% if not isExternalLimitedUi %}
                <div id="personal-documents" class="tab-content hidden">
                    <div class="ue-card">
                        <div class="ue-card-header">
                            <div class="ue-card-header-icon" style="background:#faf5ff; color:#9333ea;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V6z"/><path d="M14 2v4h4M10 10l-2 2 2 2m2-4l2 2-2 2"/></svg>
                            </div>
                            <div>
                                <div class="ue-card-header-title">Documenti Personali</div>
                                <div class="ue-card-header-sub">Documenti personali dell'operaio</div>
                            </div>
                        </div>
                        <div class="ue-card-body ue-doc-content">
                            {# TODO: include documents/documenti_personali sub-template #}
                            {{ documentiPersonali|raw }}
                        </div>
                    </div>
                </div>
            {% endif %}

            <!-- Archivio -->
            <div id="archivio" class="tab-content hidden">
                <div class="ue-card">
                    <div class="ue-card-header">
                        <div class="ue-card-header-icon" style="background:#f0fdf4; color:#16a34a;">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4h16v4H2zM4 8v8a2 2 0 002 2h8a2 2 0 002-2V8"/><path d="M8 12h4"/></svg>
                        </div>
                        <div>
                            <div class="ue-card-header-title">Storico Aziende</div>
                            <div class="ue-card-header-sub">Cronologia delle aziende precedenti</div>
                        </div>
                    </div>
                    <div class="ue-card-body" style="padding:0;">
                        <table class="ue-archive-table">
                            <thead>
                            <tr><th>Azienda</th><th>Ruolo</th><th>Dal</th><th>Al</th></tr>
                            </thead>
                            <tbody>
                            {% set hasHistory = false %}
                            {% for row in companyHistory %}
                                {% if row.end_date is not empty %}
                                    {% set hasHistory = true %}
                                <tr>
                                    <td><div class="ue-archive-company"><span class="ue-archive-dot"></span>{{ row.company }}</div></td>
                                    <td>{{ row.role }}</td>
                                    <td><span class="ue-archive-date">{{ row.start_date }}</span></td>
                                    <td><span class="ue-archive-date">{{ row.end_date }}</span></td>
                                </tr>
                                {% endif %}
                            {% endfor %}
                            {% if not hasHistory %}
                                <tr><td colspan="4" style="text-align:center; padding:32px; color:#94a3b8; font-size:13px;">Nessun record nello storico</td></tr>
                            {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal per Foto Profilo -->
<div id="image-preview-modal" class="modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="font-medium text-lg">
                    Foto Profilo – <span id="preview-worker-name" class="text-slate-600 font-normal"></span>
                </h2>
                <button type="button" class="btn-close" data-tw-dismiss="modal" aria-label="Chiudi"></button>
            </div>

            <div class="modal-body flex justify-center items-center">
                <img id="preview-image" src="" alt="Foto Operaio" class="max-h-[80vh] rounded-lg shadow-md">
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/users/edit.js"></script>
{% endblock %}
