{% extends 'layout/base.html.twig' %}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/users/workers_list.css">
{% endblock %}

{% block content %}
{% set avatarColors = ['#1d4ed8','#7c3aed','#0f766e','#b45309','#be185d','#4338ca','#15803d','#9333ea'] %}

<div class="wl-page">
    <!-- Hero -->
    <div class="wl-hero">
        <svg class="wl-hero-wm" viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="80" stroke="white" stroke-width="8"/>
            <circle cx="100" cy="70" r="28" stroke="white" stroke-width="8"/>
            <path d="M45 160c0-30 24-55 55-55s55 25 55 55" stroke="white" stroke-width="8" stroke-linecap="round"/>
        </svg>
        <div class="wl-hero-top">
            <div class="wl-hero-icon">
                <svg width="24" height="24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div>
                <h1 class="wl-hero-title">Operai</h1>
                <p class="wl-hero-sub">Tutti gli operai delle tue aziende</p>
            </div>
        </div>
        <div class="wl-hero-pills">
            <div class="wl-pill">
                <span class="wl-pill-num">{{ totalWorkers }}</span> Totali
            </div>
            <div class="wl-pill">
                <svg width="8" height="8"><circle cx="4" cy="4" r="4" fill="#22c55e"/></svg>
                <span class="wl-pill-num">{{ totalActive }}</span> Attivi
            </div>
            <div class="wl-pill">
                <svg width="8" height="8"><circle cx="4" cy="4" r="4" fill="#ef4444"/></svg>
                <span class="wl-pill-num">{{ totalInactive }}</span> Inattivi
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <form method="GET" class="wl-toolbar">
        <a href="/users/create" style="display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,#312e81,#7c3aed);color:#fff;font-size:13px;font-weight:700;padding:9px 18px;border-radius:10px;text-decoration:none;box-shadow:0 4px 14px rgba(124,58,237,0.3);transition:opacity .15s;flex-shrink:0;" onmouseover="this.style.opacity='.88'" onmouseout="this.style.opacity='1'">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nuovo Operaio
        </a>
        <input type="text" id="wl-search-input" name="search" class="wl-search" placeholder="Cerca operaio per nome, cognome, codice fiscale..."
               value="{{ search }}">
        {% if search != '' %}
            <a href="/users/workers" style="font-size:12px; color:#7c3aed; font-weight:600; text-decoration:none;">Cancella filtro</a>
        {% endif %}
        <label class="wl-toggle-wrap" id="toggle-inactive">
            <div class="wl-toggle-track active" id="toggle-track">
                <div class="wl-toggle-thumb"></div>
            </div>
            <span class="wl-toggle-label">Mostra inattivi</span>
        </label>
        <span class="wl-filter-label">
            {{ allowedCompanyNames|length }} {{ allowedCompanyNames|length == 1 ? 'azienda' : 'aziende' }} &middot; {{ totalWorkers }} operai
        </span>
    </form>

    {% if grouped is empty %}
        <div class="wl-table-wrap">
            <div class="wl-empty">
                <div class="wl-empty-icon">
                    <svg width="24" height="24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                </div>
                <p style="font-size:14px; font-weight:600; color:#64748b; margin:0 0 4px;">Nessun operaio trovato</p>
                <p style="font-size:12px; margin:0;">
                    {% if search != '' %}
                        Prova a modificare i criteri di ricerca.
                    {% else %}
                        Non ci sono operai associati alle tue aziende.
                    {% endif %}
                </p>
            </div>
        </div>
    {% else %}
        {% set companyColors = ['#3b82f6','#6366f1','#8b5cf6','#10b981','#0ea5e9','#f59e0b','#ef4444','#14b8a6'] %}
        {% set ci = 0 %}
        {% for companyName, workers in grouped %}
            {% set dotColor = companyColors[ci % companyColors|length] %}
            {% set ci = ci + 1 %}
            {% set companyActive = 0 %}
            {% for w in workers %}
                {% if w.active == 'Y' or w.active == 1 %}
                    {% set companyActive = companyActive + 1 %}
                {% endif %}
            {% endfor %}
        <div class="wl-company-group">
            <div class="wl-company-header">
                <span class="wl-company-dot" style="background:{{ dotColor }};"></span>
                <h2 class="wl-company-name">{{ companyName }}</h2>
                <span class="wl-company-count">{{ workers|length }} operai &middot; {{ companyActive }} attivi</span>
                <svg class="wl-company-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="wl-table-wrap">
                <table class="wl-table">
                    <thead>
                        <tr>
                            <th>Operaio</th>
                            <th>Tipo</th>
                            <th>Stato</th>
                            <th style="text-align:right;">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for w in workers %}
                            {% set isActive = (w.active == 'Y' or w.active == 1) %}
                            {% set fullName = w.last_name ~ ' ' ~ w.first_name %}
                            {% set initials = (w.first_name|slice(0,1) ~ w.last_name|slice(0,1))|upper %}
                            {% set bgColor = avatarColors[w.id % avatarColors|length] %}
                        <tr data-active="{{ isActive ? '1' : '0' }}" data-href="/users/{{ w.id }}/edit?uid={{ w.uid }}">
                            <td>
                                <div class="wl-entity">
                                    {% if w.photo is not empty %}
                                        <img class="wl-photo" src="/users/{{ w.id }}/worker-photo?uid={{ w.uid }}" alt="">
                                    {% else %}
                                        <div class="wl-avatar" style="background:{{ bgColor }};">{{ initials }}</div>
                                    {% endif %}
                                    <div>
                                        <div class="wl-name">{{ fullName }}</div>
                                        {% if w.fiscal_code is not empty %}
                                            <div class="wl-fiscal">{{ w.fiscal_code }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% if w.type_worker is not empty %}
                                    <span class="wl-type">{{ w.type_worker }}</span>
                                {% else %}
                                    <span style="color:#cbd5e1;">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if isActive %}
                                    <span class="wl-badge wl-badge-active">Attivo</span>
                                {% else %}
                                    <span class="wl-badge wl-badge-inactive">Inattivo</span>
                                {% endif %}
                            </td>
                            <td class="wl-actions-cell">
                                <div class="wl-actions">
                                    <a href="/users/{{ w.id }}/edit?uid={{ w.uid }}" class="wl-btn-open">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                        Apri Profilo
                                    </a>
                                    <button type="button" class="wl-btn-del" title="Elimina" data-id="{{ w.id }}" data-uid="{{ w.uid }}">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endfor %}
    {% endif %}
</div>

<!-- ── DELETE MODAL ─────────────────────────── -->
<div id="wl-delete-modal" class="modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="wl-delete-form" action="" method="POST" class="modal-content">
            <div class="modal-body p-0">
                <div style="padding:28px 24px 0;text-align:center;">
                    <div class="wl-del-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                    </div>
                    <p class="wl-del-title">Elimina Operaio</p>
                    <p class="wl-del-sub">Sei sicuro di voler eliminare questo operaio?<br>Questa azione non può essere annullata.</p>
                </div>
                <div class="wl-del-bar" style="padding:0 24px 24px;">
                    <input type="hidden" id="wl-delete-id" value="">
                    <button type="button" data-tw-dismiss="modal" class="wl-del-cancel">Annulla</button>
                    <button type="submit" class="wl-del-confirm">Elimina</button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/users/workers_list.js?v=4"></script>
{% endblock %}
