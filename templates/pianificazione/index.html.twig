{% extends "layout/base.html.twig" %}

{#
  Variables expected from ProgrammazioneController::index() (pianificazione route):
    allWorkers       – array of workers: id, first_name, last_name, company, is_nostro
    nosTriCount      – int (count of workers where is_nostro == true); pre-computed by controller
    workersJson      – JSON string of allWorkers (passed raw to JS)
    consorziate      – array: id, name, tot_workers
    consorziateJson  – JSON string of consorziate
#}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/pianificazione/pianificazione.css">
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.min.css" rel="stylesheet">
{% endblock %}

{% block content %}
<div class="pn-wrap">

    <div class="pn-header">
        <h2>
            <i data-lucide="clipboard-list" style="width:22px;height:22px;color:#3b82f6;"></i>
            Pianificazione Squadre
        </h2>
        <div class="pn-toolbar">
            <div class="pn-date-nav">
                <button class="pn-date-btn" id="pn-date-prev">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <input type="date" id="pianDate">
                <button class="pn-date-btn" id="pn-date-next">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
            </div>
            <button class="pn-btn pn-btn-secondary" id="pn-copy-btn">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                Copia da ieri
            </button>
            <button class="pn-btn pn-btn-success" id="pn-save-btn">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
                Salva
            </button>
            <button class="pn-btn pn-btn-secondary" id="pn-print-btn">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Stampa
            </button>
        </div>
    </div>

    <div class="pn-layout">

        <!-- Sidebar: available workers -->
        <div class="pn-sidebar">
            <div class="pn-sidebar-head">
                Operai nostri
                <span class="pn-sb-count" id="sbCount">0 / {{ nosTriCount }}</span>
            </div>
            <div class="pn-sidebar-search">
                <input type="text" placeholder="Cerca..." id="sbSearch">
            </div>
            <div class="pn-sidebar-list" id="sbList"></div>
        </div>

        <!-- Main content -->
        <div class="pn-main">
            <div class="pn-stats">
                <div class="pn-stat">
                    <div class="pn-stat-icon" style="background:#eff6ff;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    </div>
                    <div><div class="pn-stat-value" id="statCantieri">0</div><div class="pn-stat-label">Cantieri</div></div>
                </div>
                <div class="pn-stat">
                    <div class="pn-stat-icon" style="background:#f0fdf4;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    </div>
                    <div><div class="pn-stat-value" id="statNostri">0</div><div class="pn-stat-label">Assegnati</div></div>
                </div>
                <div class="pn-stat">
                    <div class="pn-stat-icon" style="background:#fefce8;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#eab308" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    </div>
                    <div><div class="pn-stat-value" id="statCons">0</div><div class="pn-stat-label">Consorziati</div></div>
                </div>
                <div class="pn-stat">
                    <div class="pn-stat-icon" style="background:#f0f9ff;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/></svg>
                    </div>
                    <div><div class="pn-stat-value" id="statDisponibili">0</div><div class="pn-stat-label">Disponibili</div></div>
                </div>
            </div>

            <div id="pianoList" class="pn-list">
                <div class="pn-empty" id="emptyState">
                    <p style="font-weight:600;">Nessun cantiere pianificato</p>
                    <p>Clicca "Aggiungi Cantiere" per iniziare</p>
                </div>
            </div>

            <div class="pn-add-wrap">
                <button class="pn-btn pn-btn-primary" id="pn-add-row-btn">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Aggiungi Cantiere
                </button>
            </div>
        </div>

    </div><!-- /pn-layout -->

</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
<script nonce="{{ cspNonce }}">
const ALL_WORKERS    = {{ workersJson|raw }};
const ALL_CONSORZIATE = {{ consorziateJson|raw }};
</script>
<script src="/assets/js/views/pianificazione/pianificazione.js"></script>
{% endblock %}
