                    <i data-lucide="send" class="w-4 h-4 mr-1"></i> Invia
                </button>
            </div>
            <div id="ai-status" class="text-xs text-slate-400 mt-1.5 h-4"></div>

        </div>
        </div>

        {# ════════════════════════════════════════════════════════════
           TAB: Attività
           ════════════════════════════════════════════════════════════ #}
        {% if canSeePrices %}
        <div class="tab-pane fade" id="attivita" role="tabpanel">

            <div class="flex justify-between items-center mb-3">
                <span class="text-muted text-sm">
                    {% if totaleGiornateUomo > 0 %}
                        Totale G/U: <strong>{{ totaleGiornateUomo|number_format(1, ',', '.') }}</strong>
                    {% endif %}
                </span>
                <button class="btn btn-primary text-sm px-4 py-2"
                        data-tw-toggle="modal"
                        data-tw-target="#attivita-modal">
                    <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Aggiungi Attività
                </button>
            </div>

            <div class="w-full overflow-x-auto">
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Attività</th>
                            <th>Persone</th>
                            <th>Ore</th>
                            <th>G/U</th>
                            <th>Q.tà</th>
                            <th>Attrezzature</th>
                            <th>Problemi</th>
                            <th>Soluzioni</th>
                            <th>Note</th>
                            <th>Foto</th>
                            <th>Aggiunto da</th>
                            <th class="w-40 text-center">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% if attivita is not empty %}
                        {% for a in attivita %}
                        {% set rowPhotos = attivitaPhotos[a.id]|default([]) %}
                        <tr>
                            <td class="text-nowrap">
                                {% if a.data is not empty %}{{ a.data|date('d/m/Y') }}{% else %}-{% endif %}
                            </td>
                            <td>{{ a.attivita ?: '-' }}</td>
                            <td>{{ a.persone_impiegate ?: '-' }}</td>
                            <td>{{ a.tempo_ore ?: '-' }}</td>
                            <td>{{ a.giornata_uomo ?: '-' }}</td>
                            <td>{{ a.quantita ?: '-' }}</td>
                            <td>{{ a.attrezzature_impiegate ?: '-' }}</td>
                            <td>{{ a.problemi ?: '-' }}</td>
                            <td>{{ a.soluzioni ?: '-' }}</td>
                            <td>{{ a.note ?: '-' }}</td>
                            <td>
                                {% if rowPhotos|length > 0 %}
                                    <button class="btn btn-sm btn-link p-0 open-att-lightbox"
                                            data-photos="{{ rowPhotos|json_encode|e('html_attr') }}">
                                        📷 {{ rowPhotos|length }}
                                    </button>
                                {% else %}-{% endif %}
                            </td>
                            <td class="text-nowrap">
                                {% if a.created_by_name is defined and a.created_by_name %}
                                    {{ a.created_by_name }}
                                {% else %}-{% endif %}
                                {% if a.created_at is defined and a.created_at %}
                                    <br><small class="text-muted">{{ a.created_at|date('d/m/Y') }}</small>
                                {% endif %}
                            </td>
                            <td>
                                <div class="flex justify-center items-center">
                                    <button class="flex items-center mr-3 edit-attivita-btn"
                                            data-id="{{ a.id }}"
                                            data-data="{{ a.data ?? '' }}"
                                            data-attivita="{{ a.attivita ?? '' }}"
                                            data-persone="{{ a.persone_impiegate ?? '' }}"
                                            data-tempo="{{ a.tempo_ore ?? '' }}"
                                            data-quantita="{{ a.quantita ?? '' }}"
                                            data-giuomo="{{ a.giornata_uomo ?? '' }}"
                                            data-attrezzature="{{ a.attrezzature_impiegate ?? '' }}"
                                            data-problemi="{{ a.problemi ?? '' }}"
                                            data-soluzioni="{{ a.soluzioni ?? '' }}"
                                            data-note="{{ a.note ?? '' }}"
                                            data-photos="{{ rowPhotos|json_encode|e('html_attr') }}"
                                            data-tw-toggle="modal"
                                            data-tw-target="#attivita-modal">
                                        <i data-lucide="edit" class="w-4 h-4 mr-1"></i> Modifica
                                    </button>
                                    <form method="POST"
                                          action="/worksites/{{ worksite_id }}/attivita/{{ a.id }}/delete"
                                          data-confirm="Eliminare questa attività?"
                                          class="inline-block">
                                        <button type="submit" class="flex items-center text-danger">
                                            <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Elimina
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="13" class="text-center text-slate-500">Nessuna attività registrata per questo cantiere.</td></tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <!-- Modal Add/Edit Attività -->
            <div id="attivita-modal"
                 class="modal"
                 tabindex="-1"
                 aria-hidden="true"
                 data-tw-backdrop="static"
                 data-tw-keyboard="false">
                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                    <form method="POST" action="/worksites/{{ worksite_id }}/attivita"
                          enctype="multipart/form-data" class="modal-content">
                        <div class="modal-header">
                            <h2 class="font-medium text-base mr-auto" id="attivita-modal-title">Aggiungi / Modifica Attività</h2>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="id" id="attivita-id">
                            <input type="hidden" name="worksite_id" value="{{ worksite_id }}">

                            <div class="row">
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Data <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="data" id="attivita-data" required>
                                </div>
                                <div class="col-md-2 mb-3">
                                    <label class="form-label">N° Persone</label>
                                    <input type="number" min="0" step="1" class="form-control" name="persone_impiegate" id="attivita-persone" placeholder="0">
                                </div>
                                <div class="col-md-2 mb-3">
                                    <label class="form-label">Ore</label>
                                    <input type="number" min="0" step="0.5" class="form-control" name="tempo_ore" id="attivita-tempo" placeholder="8">
                                </div>
                                <div class="col-md-2 mb-3">
                                    <label class="form-label">G/U</label>
                                    <input type="number" min="0" step="0.5" class="form-control" name="giornata_uomo" id="attivita-giuomo" placeholder="1">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Quantità</label>
                                    <input type="text" class="form-control" name="quantita" id="attivita-quantita" placeholder="es. 100 mq">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Attrezzature impiegate</label>
                                <input type="text" class="form-control" name="attrezzature_impiegate" id="attivita-attrezzature"
                                       placeholder="muletto, piattaforma, …">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Attività <span class="text-danger">*</span></label>
                                <textarea class="form-control" name="attivita" id="attivita-attivita" rows="3" required
                                          placeholder="Descrivi l'attività svolta..."></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Problemi</label>
                                <textarea class="form-control" name="problemi" id="attivita-problemi" rows="2"
                                          placeholder="Eventuali problemi riscontrati..."></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Soluzioni</label>
                                <textarea class="form-control" name="soluzioni" id="attivita-soluzioni" rows="2"
                                          placeholder="Soluzioni applicate..."></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Note</label>
                                <textarea class="form-control" name="note" id="attivita-note" rows="2"
                                          placeholder="Altro..."></textarea>
                            </div>

                            <hr class="my-3">

                            <!-- Foto: Problemi -->
                            <div class="mb-3">
                                <label class="form-label">⚠️ Foto Problemi</label>
                                <div id="att-grid-problemi" class="att-photo-grid mb-2"></div>
                                <input type="file" class="form-control" name="photos_problemi[]"
                                       id="att-input-problemi" multiple accept="image/*">
                            </div>

                            <!-- Foto: Soluzioni -->
                            <div class="mb-3">
                                <label class="form-label">✅ Foto Soluzioni</label>
                                <div id="att-grid-soluzioni" class="att-photo-grid mb-2"></div>
                                <input type="file" class="form-control" name="photos_soluzioni[]"
                                       id="att-input-soluzioni" multiple accept="image/*">
                            </div>

                            <!-- Foto: Info / Generale -->
                            <div class="mb-3">
                                <label class="form-label">📋 Foto Info / Generale</label>
                                <div id="att-grid-info" class="att-photo-grid mb-2"></div>
                                <input type="file" class="form-control" name="photos_info[]"
                                       id="att-input-info" multiple accept="image/*">
                            </div>
                        </div>
                        <div class="modal-footer text-right">
                            <button type="button" data-tw-dismiss="modal" class="btn btn-outline-secondary w-20 mr-2">Chiudi</button>
                            <button type="submit" class="btn btn-primary w-20">Salva</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Lightbox -->
            <div id="attivita-lightbox" class="att-lightbox" aria-hidden="true">
                <button class="att-lightbox-close" id="att-lb-close" aria-label="Chiudi">&times;</button>
                <button class="att-lightbox-prev" id="att-lb-prev">&#8249;</button>
                <img class="att-lightbox-img" id="att-lb-img" src="" alt="">
                <button class="att-lightbox-next" id="att-lb-next">&#8250;</button>
                <div class="att-lightbox-caption" id="att-lb-caption"></div>
            </div>

        </div>
        {% endif %}

        {# ════════════════════════════════════════════════════════════
           TAB: Extra
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade" id="extra" role="tabpanel">
            <div class="flex justify-end mb-3">
                <button class="btn btn-primary text-sm px-4 py-2"
                        data-tw-toggle="modal"
                        data-tw-target="#extra-modal">
                    <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Aggiungi Extra
                </button>
            </div>

            <div class="w-full overflow-x-auto">
                <table class="table table-sm table-striped">
                    <thead>
                    <tr>
                        <th>Data</th>
                        <th>Ordine</th>
                        <th>Descrizione</th>
                        <th>Totale (€)</th>
                        <th class="w-40 text-center">Azioni</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if extra is not empty %}
                        {% for e in extra %}
                            <tr>
                                <td>{{ e.data|date('d/m/Y') }}</td>
                                <td>{{ e.ordine }}</td>
                                <td>{{ e.descrizione|nl2br }}</td>
                                <td>{{ e.totale|number_format(2) }} €</td>
                                <td>
                                    <div class="flex justify-center items-center">
                                        <button class="flex items-center mr-3 create-billing-from-extra"
                                                data-extra-id="{{ e.id }}"
                                                data-data="{{ e.data }}"
                                                data-ordine="{{ e.ordine }}"
                                                data-cantiere="{{ worksite.getName() }}"
                                                data-descrizione="{{ e.descrizione }}"
                                                data-totale="{{ e.totale }}">
                                            <i data-lucide="file-plus" class="w-4 h-4 mr-1"></i> Fattura
                                        </button>
                                        <button class="flex items-center mr-3 edit-extra-btn"
                                                data-id="{{ e.id }}"
                                                data-data="{{ e.data }}"
                                                data-ordine="{{ e.ordine }}"
                                                data-descrizione="{{ e.descrizione }}"
                                                data-totale="{{ e.totale }}"
                                                data-tw-toggle="modal"
                                                data-tw-target="#extra-modal">
                                            <i data-lucide="edit" class="w-4 h-4 mr-1"></i> Modifica
                                        </button>
                                        <form method="POST" action="/worksites/{{ worksite_id }}/extra/{{ e.id }}/delete"
                                              data-confirm="Eliminare questo extra?"
                                              class="inline-block">
                                            <button type="submit" class="flex items-center text-danger">
                                                <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Elimina
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="5" class="text-center text-slate-500">Nessun extra registrato.</td></tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <div id="extra-modal" class="modal" tabindex="-1" aria-hidden="true" data-tw-backdrop="static" data-tw-keyboard="false">
                <div class="modal-dialog" style="max-width: 600px;">
                    <form method="POST" action="/worksites/{{ worksite_id }}/extra" class="modal-content">
                        <div class="modal-header">
                            <h2 class="font-medium text-base mr-auto" id="extra-modal-title">Aggiungi / Modifica Extra</h2>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="id" id="extra-id">
                            <input type="hidden" name="worksite_id" value="{{ worksite_id }}">
                            <div class="mb-3">
                                <label class="form-label">Data</label>
                                <input type="date" class="form-control" name="data" id="extra-data" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Ordine</label>
                                <input type="text" class="form-control" name="ordine" id="extra-ordine">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Descrizione</label>
                                <textarea class="form-control" name="descrizione" id="extra-descrizione" rows="3"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Totale (€)</label>
                                <input type="number" step="0.01" class="form-control" name="totale" id="extra-totale" required>
                            </div>
                        </div>
                        <div class="modal-footer text-right">
                            <button type="button" data-tw-dismiss="modal" class="btn btn-outline-secondary w-20 mr-2">Chiudi</button>
                            <button type="submit" class="btn btn-primary w-20">Salva</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# ════════════════════════════════════════════════════════════
           TAB: Fatturazione
           NOTE: billing.php had inline PHP computations for defaultDescr,
                 remaining, isEdit, editVat, defaultVatId — these are now
                 passed from the controller as: billingDefaultDescr,
                 billingRemaining. defaultVatId is hardcoded as 15.
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade" id="billing" role="tabpanel">
            <div class="flex justify-end mb-3">
                <button class="btn btn-primary text-sm px-4 py-2"
                        data-tw-toggle="modal"
                        data-tw-target="#billing-modal">
                    <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Aggiungi Fattura
                </button>
            </div>

            <div class="w-full overflow-x-auto">
                <table class="table table-sm table-striped">
                    <thead>
                    <tr>
                        <th>Data</th>
                        <th>Articolo</th>
                        <th>Descrizione</th>
                        <th>Totale (€)</th>
                        <th>IVA</th>
                        <th>Stato</th>
                        <th class="w-40 text-center">Azioni</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if fatture is not empty %}
                        {% for e in fatture %}
                            <tr>
                                <td>{{ e.data|date('d/m/Y') }}</td>
                                <td>{{ e.articolo_codice }} - {{ e.articolo_descrizione }}</td>
                                <td>{{ e.descrizione|nl2br }}</td>
                                <td>{{ e.totale_imponibile|number_format(2, ',', '.') }} €</td>
                                <td>{{ e.aliquota_iva|number_format(0, ',', '.') }}%</td>
                                <td>
                                    {% if e.emessa_reale is not empty %}
                                        <span class="px-2 py-1 text-xs rounded bg-green-100 text-green-800">Emessa</span>
                                    {% else %}
                                        <span class="px-2 py-1 text-xs rounded bg-yellow-100 text-yellow-800">Non emessa</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="flex justify-center items-center">
                                        <button class="flex items-center mr-3 edit-billing-btn"
                                                data-id="{{ e.id }}"
                                                data-data="{{ e.data }}"
                                                data-articolo-id="{{ e.articolo_id }}"
                                                data-descrizione="{{ e.descrizione }}"
                                                data-totale="{{ e.totale_imponibile }}"
                                                data-iva="{{ e.iva_id }}"
                                                data-tw-toggle="modal"
                                                data-tw-target="#billing-modal">
                                            <i data-lucide="edit" class="w-4 h-4 mr-1"></i> Modifica
                                        </button>
                                        <form method="POST" action="/worksites/{{ worksite_id }}/billing/{{ e.id }}/delete"
                                              data-confirm="Eliminare questa fattura?"
                                              class="inline-block">
                                            <button type="submit" class="flex items-center text-danger">
                                                <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Elimina
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="6" class="text-center text-slate-500">Nessuna fattura registrata.</td></tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <!-- Modal Aggiungi / Modifica Fattura -->
            <div id="billing-modal" class="modal" tabindex="-1" aria-hidden="true" data-tw-backdrop="static" data-tw-keyboard="false">
                <div class="modal-dialog" style="max-width:600px;">
                    <form method="POST" action="/worksites/{{ worksite_id }}/billing" class="modal-content">
                        <div class="modal-header">
                            <h2 id="billing-modal-title">Aggiungi / Modifica Fattura</h2>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="id" id="billing-id">
                            <input type="hidden" name="worksite_id" value="{{ worksite_id }}">
                            <input type="hidden" name="extra_id" id="billing-extra-id">
                            <div class="mb-3">
                                <label>Data</label>
                                <input type="date" name="data" id="billing-data" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label>Articolo</label>
                                <select name="articolo_id" id="billing-ordine" class="tomselect" required>
                                    {% for a in articles %}
                                        <option value="{{ a.id }}" {% if a.codice == 'MONT' %}selected{% endif %}>
                                            {{ a.codice }} - {{ a.descrizione }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="mb-3">
                                <label>Descrizione</label>
                                <textarea name="descrizione" id="billing-descrizione"
                                          class="form-control" rows="3" required>{{ billingDefaultDescr }}</textarea>
                            </div>
                            <div class="mb-3">
                                <label>Totale €</label>
                                <input type="text" name="totale" id="billing-totale"
                                       class="form-control"
                                       value="{{ billingRemaining|number_format(2, ',', '.') }}"
                                       required>
                            </div>
                            <div class="mb-3">
                                <label>Codice IVA</label>
                                <select name="iva_id" id="billing-iva" class="tomselect" required>
                                    {% for id, desc in vatCodes %}
                                        <option value="{{ id }}" {% if id == 15 %}selected{% endif %}>
                                            {{ desc }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" data-tw-dismiss="modal" class="btn btn-outline-secondary">Chiudi</button>
                            <button type="submit" class="btn btn-primary">Salva</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {% endif %}{# end !isWorker #}

        {# ════════════════════════════════════════════════════════════
           TAB: Disegni
           NOTE: isOffice = user.type not in ['worker','client']
                 totalDisegni and existingCategories passed from controller
           ════════════════════════════════════════════════════════════ #}
        {# TODO: controller should pass isOffice, totalDisegni, existingCategories explicitly #}
        {% set isOffice = userObj.type not in ['worker', 'client'] %}
        {% set totalDisegni = 0 %}
        {% for catItems in disegniByCategory %}
            {% set totalDisegni = totalDisegni + catItems|length %}
        {% endfor %}
        {% set existingCategories = disegniByCategory|keys|sort %}

        <div class="tab-pane fade" id="disegni" role="tabpanel" data-worksite="{{ worksite_id }}">

            <!-- Header -->
            <div class="dsg-header">
                <div style="display:flex;align-items:center;gap:10px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:.85;flex-shrink:0;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <h3 style="margin:0;">Disegni</h3>
                    <span class="dsg-count">{{ totalDisegni }} file</span>
                </div>
                {% if isOffice %}
                    <button type="button" class="dsg-upload-btn" id="dsg-upload-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        Carica Disegno
                    </button>
                {% endif %}
            </div>

            {% if disegniByCategory is not empty %}
                {% for catName, items in disegniByCategory %}
                    {# Use a URL-safe slug derived from the category name for DOM IDs #}
                    {% set catId = catName|replace({' ': '-', '/': '-', '.': '-', '(': '', ')': '', '[': '', ']': ''})|lower %}
                    <div class="dsg-cat">
                        <!-- Category Header -->
                        <button type="button" class="dsg-cat-head toggle-category" data-target="cat-{{ catId }}">
                            <div class="dsg-cat-left">
                                <div class="dsg-cat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                                </div>
                                <span class="dsg-cat-name">{{ catName }}</span>
                            </div>
                            <div class="dsg-cat-right">
                                {% if isOffice %}
                                    <button type="button" class="dsg-cat-share-btn"
                                            title="Condividi tutta la categoria"
                                            data-action="dsg-share-cat"
                                            data-cat="{{ catName }}">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                                        Condividi
                                    </button>
                                {% endif %}
                                <span class="dsg-cat-badge">{{ items|length }} file</span>
                                <span class="dsg-cat-arrow open">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                                </span>
                            </div>
                        </button>

                        <!-- File List -->
                        <div id="cat-{{ catId }}" class="dsg-cat-body">
                            {% for d in items %}
                                {% set ver = d.current_version ?? 1 %}
                                {% set ext = (d.file_type ?? 'pdf')|lower %}
                                {% set uploaderName = ((d.uploader_first ?? '') ~ ' ' ~ (d.uploader_last ?? ''))|trim %}
                                {% set sharedUserIds = sharedMap[d.id] ?? [] %}
                                {% set iconClass = ext in ['pdf','dwg','png','jpg','jpeg'] ? ext : 'default' %}

                                <div class="dsg-row" id="row-{{ d.id }}">
                                    <!-- File type icon -->
                                    <div class="dsg-file-icon {{ iconClass }}">{{ ext|upper }}</div>

                                    <!-- File info -->
                                    <div class="dsg-file-info">
                                        <div class="dsg-file-name">
                                            {{ d.file_name }}
                                            {% if sharedUserIds is not empty and isOffice %}
                                                <span class="dsg-shared-badge">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                                    {{ sharedUserIds|length }}
                                                </span>
                                            {% endif %}
                                        </div>
                                        <div class="dsg-file-meta">
                                            <span>{{ d.created_at|date('d/m/Y') }}</span>
                                            {% if isOffice and uploaderName %}
                                                <span>{{ uploaderName }}</span>
                                            {% endif %}
                                            {% if d.note is not empty %}
                                                <span class="dsg-note-badge" title="{{ d.note }}">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                                                    Nota
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <!-- Version badge -->
                                    <span class="dsg-version {{ ver > 1 ? 'vn' : 'v1' }}">v{{ ver }}</span>

                                    <!-- Actions -->
                                    <div class="dsg-actions">
                                        <a href="/worksites/{{ worksite_id }}/disegni/{{ d.id }}/view"
                                           target="_blank" class="dsg-act dsg-act-open" title="Apri">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                            <span class="hidden sm:inline">Apri</span>
                                        </a>
                                        {% if ver > 1 %}
                                            <button type="button" class="dsg-act dsg-act-history"
                                                    title="Cronologia versioni"
                                                    data-action="dsg-versions"
                                                    data-id="{{ d.id }}"
                                                    data-worksite="{{ worksite_id }}">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                                <span class="hidden sm:inline">v{{ ver }}</span>
                                            </button>
                                        {% endif %}
                                        {% if isOffice %}
                                            <button type="button" class="dsg-act dsg-act-update"
                                                    title="Carica nuova versione"
                                                    data-action="dsg-update"
                                                    data-id="{{ d.id }}"
                                                    data-cat="{{ catName }}">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                            </button>
                                            <button type="button" class="dsg-act dsg-act-share"
                                                    title="Condividi con utenti"
                                                    data-action="dsg-share"
                                                    data-id="{{ d.id }}"
                                                    data-shared="{{ sharedUserIds|json_encode }}">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                                            </button>
                                            <button type="button" class="dsg-act dsg-act-delete"
                                                    title="Elimina"
                                                    data-action="dsg-delete"
                                                    data-id="{{ d.id }}"
                                                    data-name="{{ d.file_name }}">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        {% endif %}
                                    </div>
                                </div>

                                <!-- Version History (hidden by default) -->
                                <div id="versions-{{ d.id }}" class="dsg-versions-row" style="display:none;">
                                    <div id="versions-body-{{ d.id }}">
                                        <span class="dsg-versions-loading">Caricamento...</span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="dsg-empty">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <p>Nessun disegno caricato per questo cantiere.</p>
                    {% if isOffice %}
                        <button type="button" class="dsg-upload-btn dsg-empty-btn" id="dsg-upload-btn-empty">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            Carica il primo disegno
                        </button>
                    {% endif %}
                </div>
            {% endif %}

        </div>{# end #disegni tab-pane #}

        {% if isOffice %}

        <!-- MODAL: Upload / Update -->
        <div id="disegno-modal" class="modal dsg-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog" style="max-width:520px;">
                <form method="POST" id="disegno-form"
                      action="/worksites/{{ worksite_id }}/disegni/upload"
                      enctype="multipart/form-data" class="modal-content">
                    <div class="modal-header">
                        <h2 id="modal-title">Carica Disegno</h2>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="worksite_id" value="{{ worksite_id }}">
                        <input type="hidden" name="type" value="disegni">
                        <input type="hidden" name="replace_id" id="replace-id" value="0">

                        <div class="mb-4" id="category-section">
                            <label class="form-label">Categoria / Cartella</label>
                            {% if existingCategories is not empty %}
                                <select id="existing-category" class="form-control mb-2">
                                    <option value="">— Seleziona esistente —</option>
                                    {% for cat in existingCategories %}
                                        <option value="{{ cat }}">{{ cat|capitalize }}</option>
                                    {% endfor %}
                                </select>
                            {% endif %}
                            <input type="text" name="folder" id="category-input" class="form-control"
                                   placeholder="Oppure scrivi una nuova categoria" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">File</label>
                            <div class="dsg-drop-zone" id="drop-zone">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 8px;display:block;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                <p style="font-size:13px;color:#64748b;margin-bottom:8px;">Trascina qui il file oppure</p>
                                <input type="file" name="file" accept=".pdf,.dwg,.png,.jpg,.jpeg"
                                       class="form-control" required id="file-input" style="max-width:280px;margin:0 auto;">
                                <p id="file-name-preview" class="dsg-file-preview" style="display:none;"></p>
                            </div>
                        </div>

                        <div>
                            <label class="form-label">Note (opzionale)</label>
                            <textarea name="note" class="form-control" rows="2"
                                      placeholder="Descrizione o note sul disegno"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" data-tw-dismiss="modal"
                                class="btn btn-outline-secondary" style="border-radius:8px;">Annulla</button>
                        <button type="submit" class="btn btn-primary" id="modal-submit-btn"
                                style="border-radius:8px;padding:8px 24px;">Carica</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- MODAL: Share -->
        <div id="share-modal" class="modal dsg-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog" style="max-width:440px;">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 id="share-modal-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:6px;"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                            Condividi Disegno
                        </h2>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="share-doc-ids" value="">
                        <input type="hidden" id="share-category" value="">
                        {% if worksiteUsers is empty %}
                            <div style="text-align:center;padding:20px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" style="margin:0 auto 10px;display:block;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                <p style="font-size:13px;color:#94a3b8;">Nessun utente ha accesso a questo cantiere.</p>
                                <p style="font-size:12px;color:#cbd5e1;">Aggiungi utenti dal pannello "Gestisci accessi".</p>
                            </div>
                        {% else %}
                            <p style="font-size:13px;color:#64748b;margin-bottom:12px;">Seleziona gli utenti con cui condividere:</p>
                            <div style="max-height:320px;overflow-y:auto;">
                                {% for wu in worksiteUsers %}
                                    {% set wuName = ((wu.first_name ?? '') ~ ' ' ~ (wu.last_name ?? ''))|trim %}
                                    {% if not wuName %}{% set wuName = wu.username ?? ('User #' ~ wu.user_id) %}{% endif %}
                                    {% set initials = ((wu.first_name ?? '?')|slice(0,1) ~ (wu.last_name ?? '')|slice(0,1))|upper %}
                                    <label class="dsg-share-user" for="share-u-{{ wu.user_id }}">
                                        <input type="checkbox" class="form-check-input share-user-cb"
                                               value="{{ wu.user_id }}" id="share-u-{{ wu.user_id }}"
                                               style="flex-shrink:0;">
                                        <div class="dsg-share-avatar">{{ initials }}</div>
                                        <span class="dsg-share-name">{{ wuName }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    <div class="modal-footer">
                        <button type="button" data-tw-dismiss="modal"
                                class="btn btn-outline-secondary" style="border-radius:8px;">Annulla</button>
                        <button type="button" id="dsg-share-submit"
                                class="btn btn-primary"
                                style="border-radius:8px;background:#7c3aed;border-color:#7c3aed;padding:8px 24px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                            Condividi
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- MODAL: Delete confirm -->
        <div id="dsg-delete-modal" class="modal dsg-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog" style="max-width:420px;">
                <div class="modal-content">
                    <div class="modal-header" style="border-bottom-color:#fee2e2;">
                        <h2 style="color:#e11d48;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e11d48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:6px;"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                            Elimina disegno
                        </h2>
                    </div>
                    <div class="modal-body">
                        <p style="font-size:14px;color:#475569;margin:0 0 8px;">Stai per eliminare:</p>
                        <p id="dsg-delete-name" style="font-size:13px;font-weight:600;color:#1e293b;background:#f8fafc;border-radius:6px;padding:8px 12px;margin:0 0 12px;word-break:break-all;"></p>
                        <p style="font-size:13px;color:#94a3b8;margin:0;">L'operazione non può essere annullata.</p>
                        <input type="hidden" id="dsg-delete-id" value="">
                    </div>
                    <div class="modal-footer">
                        <button type="button" data-tw-dismiss="modal"
                                class="btn btn-outline-secondary" style="border-radius:8px;">Annulla</button>
                        <button type="button" id="dsg-delete-confirm"
                                class="btn btn-danger" style="border-radius:8px;padding:8px 20px;">
                            Elimina
                        </button>
                    </div>
                </div>
            </div>
        </div>

        {% endif %}{# end isOffice modals #}

    </div>{# .wv-tabs-content #}
</div>{# .wv-tabs-wrap #}

</div><!-- .wv-page -->

{% if not isWorker %}
<!-- Delete Modal -->
<div id="wv-delete-modal" class="modal" tabindex="-1" aria-hidden="true"
     data-tw-backdrop="static" data-tw-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="POST" action="/worksites/{{ worksite_id }}/delete">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <input type="hidden" name="id" value="{{ worksite_id }}">
                <div class="modal-body p-5 text-center">
                    <div class="mx-auto mb-4 w-12 h-12 rounded-full flex items-center justify-center" style="background:#fef2f2;">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" stroke="#dc2626" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                    </div>
                    <div class="font-semibold text-lg mb-1">Eliminare questo cantiere?</div>
                    <p class="text-slate-500 text-sm">L'operazione è irreversibile. Tutti i dati associati verranno rimossi.</p>
                </div>
                <div class="modal-footer justify-center gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-tw-dismiss="modal">Annulla</button>
                    <button type="submit" class="btn btn-danger">Elimina</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Access Modal -->
<div id="worksiteAccessModal"
     class="modal"
     tabindex="-1"
     aria-hidden="true"
     data-tw-backdrop="static"
     data-tw-keyboard="false">

    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h2 class="font-medium text-base">
                    Accesso utenti – {{ worksite.getName() }}
                </h2>
            </div>

            <div class="modal-body space-y-6">

                <!-- ASSIGN USER -->
                <div>
                    <h3 class="font-medium text-sm mb-2">Assegna utente</h3>
                    <form method="POST"
                          action="/worksites/{{ worksite_id }}/assign-user"
                          class="flex gap-3 items-end">
                        <input type="hidden" name="worksite_id" value="{{ worksite_id }}">
                        <div class="flex-1">
                            <label class="form-label">Utente</label>
                            <select id="user-select" name="user_id" class="form-control" required>
                                <option value="">Seleziona utente...</option>
                                {% for u in allUsers %}
                                    <option value="{{ u.id }}">
                                        {{ u.first_name }} {{ u.last_name }} — {{ u.type|upper }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Assegna</button>
                    </form>
                </div>

                <!-- CURRENT ACCESS -->
                <div>
                    <h3 class="font-medium text-sm mb-2">Utenti con accesso</h3>
                    <div class="border rounded-md divide-y">
                        {% if assignedUsers is empty %}
                            <div class="p-3 text-slate-500 text-sm">Nessun utente assegnato</div>
                        {% else %}
                            {% for u in assignedUsers %}
                                <div class="flex items-center justify-between p-3">
                                    <div>
                                        <div class="font-medium">{{ u.first_name }} {{ u.last_name }}</div>
                                        <div class="text-slate-500 text-xs">{{ u.username }}</div>
                                    </div>
                                    <form method="POST"
                                          action="/worksites/{{ worksite_id }}/remove-user"
                                          data-confirm="Rimuovere accesso?">
                                        <input type="hidden" name="worksite_id" value="{{ worksite_id }}">
                                        <input type="hidden" name="user_id" value="{{ u.id }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Rimuovi</button>
                                    </form>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

            </div>

            <div class="modal-footer text-right">
                <button type="button" class="btn btn-outline-secondary" data-tw-dismiss="modal">Chiudi</button>
            </div>

        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
    <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
    <script src="/assets/js/includes/worksite_views/presenze.js"></script>
