{% extends "layout/base.html.twig" %}

{% block head %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/assets/css/views/worksites/view.css">
    <link rel="stylesheet" href="/assets/css/includes/worksite_views/tab-content.css">
    <link rel="stylesheet" href="/assets/css/includes/worksite_views/presenze.css">
    <link rel="stylesheet" href="/assets/css/includes/worksite_views/presenze_consorziate.css">
    <link rel="stylesheet" href="/assets/css/includes/worksite_views/ai.css">
    <link rel="stylesheet" href="/assets/css/includes/worksite_views/disegni.css?v=2">
    <link rel="stylesheet" href="/assets/css/includes/worksite_views/attivita.css">
    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css"/>
{% endblock %}

{% block content %}
{# ── Pre-computed values (passed from controller) ── #}
{# orderDateFormatted, clientName, clientId are expected from controller #}
{# TODO: controller should pass orderDateFormatted, clientName, clientId explicitly #}

<div class="wv-page">

<!-- Hero -->
<div class="wv-hero">
    <div class="wv-hero-content">
        <div class="wv-hero-left">
            <div class="wv-hero-icon">
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 20h20"/><path d="M5 20V6l7-3 7 3v14"/><path d="M9 20v-4h6v4"/><path d="M9 10h1"/><path d="M14 10h1"/>
                </svg>
            </div>
            <div>
                <h1 class="wv-hero-title">{{ worksite.getName() }}</h1>
                <p class="wv-hero-sub">{{ worksite.getWorksiteCode() }} · {{ worksite.getLocation() ?: '-' }}</p>
            </div>
        </div>
        <div class="wv-hero-pills">
            {% if clientName %}
            <div class="wv-pill">
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                {{ clientName }}
            </div>
            {% endif %}
            {% if worksite.getOrderNumber() %}
            <div class="wv-pill">
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                Ordine: {{ worksite.getOrderNumber() }}
            </div>
            {% endif %}
            {% if worksite.isConsuntivo() %}
            <div class="wv-pill" style="background:rgba(251,191,36,.18);color:#fbbf24;border:1px solid rgba(251,191,36,.3);">
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Consuntivo{% if worksite.getPrezzoPersona() %} · € {{ worksite.getPrezzoPersona()|number_format(2, ',', '.') }}/gg{% endif %}
            </div>
            {% endif %}
        </div>
    </div>
    {% if not isWorker %}
    <div style="position:relative;z-index:1;display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;">
        <a href="/worksites/{{ worksite_id }}/edit" class="wv-btn wv-btn-primary">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Modifica
        </a>
        <button type="button" class="wv-btn wv-btn-outline" data-tw-toggle="modal" data-tw-target="#worksiteAccessModal">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Gestisci accessi
        </button>
        <button type="button" class="wv-btn wv-btn-danger" data-tw-toggle="modal" data-tw-target="#wv-delete-modal">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            Elimina
        </button>
    </div>
    {% endif %}
</div>

{% if not isWorker %}
<!-- Detail Cards -->
<div class="wv-grid">

    <!-- Dettagli Cantiere -->
    <div class="wv-card">
        <div class="wv-card-header">
            <div class="wv-card-title">
                <div class="wv-card-title-icon" style="background:linear-gradient(135deg,#1d4ed8,#0ea5e9);">
                    <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                </div>
                Dettagli Cantiere
            </div>
            <a href="/worksites/{{ worksite_id }}/edit" class="wv-card-link">
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Modifica
            </a>
        </div>
        <div class="wv-card-body">
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                <div class="wv-detail-label">Cliente</div>
                <div class="wv-detail-value">
                    {% if clientName and clientId %}
                        <a href="/clients/{{ clientId }}">{{ clientName }}</a>
                    {% elseif clientName %}
                        {{ clientName }}
                    {% else %}
                        <span class="wv-detail-muted">-</span>
                    {% endif %}
                </div>
            </div>
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
                <div class="wv-detail-label">Nome</div>
                <div class="wv-detail-value">{{ worksite.getName() }}</div>
            </div>
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></div>
                <div class="wv-detail-label">Codice</div>
                <div class="wv-detail-value" style="font-family:'SF Mono','Cascadia Code','Consolas',monospace;background:#f1f5f9;padding:2px 10px;border-radius:6px;font-size:12px;">{{ worksite.getWorksiteCode() }}</div>
            </div>
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>
                <div class="wv-detail-label">N. Ordine</div>
                <div class="wv-detail-value">{{ worksite.getOrderNumber() ?: '-' }}</div>
            </div>
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
                <div class="wv-detail-label">Data Ordine</div>
                <div class="wv-detail-value">{{ orderDateFormatted }}</div>
            </div>
            {% if canSeePrices %}
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
                <div class="wv-detail-label">Offerta</div>
                <div class="wv-detail-value">
                    {% if offerId %}
                        <a href="/genera_pdf.php?offer_id={{ offerId }}" target="_blank">{{ worksite.getOfferNumber() }}</a>
                    {% else %}
                        <span class="wv-detail-muted">{{ worksite.getOfferNumber() ?: '-' }}</span>
                    {% endif %}
                </div>
            </div>
            {% endif %}
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
                <div class="wv-detail-label">Località</div>
                <div class="wv-detail-value">{{ worksite.getLocation() ?: '-' }}</div>
            </div>
            <div class="wv-detail-row">
                <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg></div>
                <div class="wv-detail-label">Descrizione</div>
                <div class="wv-detail-value">{{ worksite.getDescription() ?: '-' }}</div>
            </div>
        </div>
    </div>

    <!-- Riassunto Cantiere -->
    <div style="display:flex;flex-direction:column;gap:20px;">
        <div class="wv-card" style="flex:1;">
            <div class="wv-card-header">
                <div class="wv-card-title">
                    <div class="wv-card-title-icon" style="background:linear-gradient(135deg,#0f766e,#14b8a6);">
                        <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </div>
                    Riassunto
                </div>
            </div>
            <div class="wv-card-body">
                <div class="wv-stats">
                    {% if canSeePrices %}
                    <div class="wv-stat">
                        {% if statsSummary.is_consuntivo %}
                            <div class="wv-stat-value" style="color:#d97706;font-size:13px;font-weight:700;">€ {{ statsSummary.prezzo_persona|number_format(2, ',', '.') }}/gg</div>
                            <div class="wv-stat-label">Tariffa pers.</div>
                        {% else %}
                            <div class="wv-stat-value" style="color:#0f766e;">€ {{ worksite.getTotalOffer()|number_format(2, ',', '.') }}</div>
                            <div class="wv-stat-label">Contratto</div>
                        {% endif %}
                    </div>
                    <div class="wv-stat">
                        <div class="wv-stat-value" style="color:#7c3aed;">€ {{ worksite.getTotalExtras()|number_format(2, ',', '.') }}</div>
                        <div class="wv-stat-label">Extra</div>
                    </div>
                    <div class="wv-stat">
                        {% if statsSummary.is_consuntivo %}
                            <div class="wv-stat-value" style="color:#1d4ed8;">€ {{ statsSummary.ricavo_stimato|number_format(2, ',', '.') }}</div>
                            <div class="wv-stat-label">Ricavo stimato</div>
                        {% else %}
                            <div class="wv-stat-value" style="color:#1d4ed8;">€ {{ worksite.getGrossTotal()|number_format(2, ',', '.') }}</div>
                            <div class="wv-stat-label">Totale Lordo</div>
                        {% endif %}
                    </div>
                    <div class="wv-stat">
                        <div class="wv-stat-value" style="color:#b45309;">€ {{ worksite.getTotalBilled()|number_format(2, ',', '.') }}</div>
                        <div class="wv-stat-label">Fatturato</div>
                    </div>
                    <div class="wv-stat" style="border-color:{{ margin >= 0 ? '#d1fae5' : '#fecaca' }};">
                        <div class="wv-stat-value" style="color:{{ margin >= 0 ? '#047857' : '#dc2626' }};">€ {{ margin|number_format(2, ',', '.') }}</div>
                        <div class="wv-stat-label">Margine</div>
                    </div>
                    {% endif %}
                    <div class="wv-stat">
                        {# Show as integer if whole number, else 1 decimal place #}
                        <div class="wv-stat-value">{% if presenzeTotaliEq == presenzeTotaliEq|round(0) %}{{ presenzeTotaliEq|round(0) }}{% else %}{{ presenzeTotaliEq|number_format(1, ',', '.') }}{% endif %}</div>
                        <div class="wv-stat-label">Presenze</div>
                    </div>
                    <div class="wv-stat">
                        <div class="wv-stat-value">{{ mezzi_count }}</div>
                        <div class="wv-stat-label">Mezzi</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
{% endif %}

{% if isWorker %}
<!-- Worker simplified view -->
<div class="wv-card" style="margin-bottom:20px;">
    <div class="wv-card-header">
        <div class="wv-card-title">
            <div class="wv-card-title-icon" style="background:linear-gradient(135deg,#1d4ed8,#0ea5e9);">
                <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            Dettagli Cantiere
        </div>
    </div>
    <div class="wv-card-body">
        <div class="wv-detail-row">
            <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
            <div class="wv-detail-label">Nome</div>
            <div class="wv-detail-value">{{ worksite.getName() }}</div>
        </div>
        <div class="wv-detail-row">
            <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></div>
            <div class="wv-detail-label">Codice</div>
            <div class="wv-detail-value" style="font-family:'SF Mono','Cascadia Code','Consolas',monospace;background:#f1f5f9;padding:2px 10px;border-radius:6px;font-size:12px;">{{ worksite.getWorksiteCode() }}</div>
        </div>
        <div class="wv-detail-row">
            <div class="wv-detail-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div class="wv-detail-label">Località</div>
            <div class="wv-detail-value">{{ worksite.getLocation() ?: '-' }}</div>
        </div>
    </div>
</div>
{% endif %}

<!-- Tabs Section -->
<div class="wv-tabs-wrap">
    <div class="wv-tabs-bar" id="worksiteTabs" role="tablist">
        {% if not isWorker %}
            <button class="wv-tab-btn active" data-bs-toggle="tab" data-bs-target="#presenze">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                Presenze
            </button>
            <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#presenze_cons">
                <svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
                Presenze Cons.
            </button>
            <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#ordini">
                <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
                Ordini
            </button>
            <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#mezzi">
                <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                Mezzi
            </button>
            <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#stats">
                <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                Statistiche
            </button>
            <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#ai">
                <svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                Assistente AI
            </button>
            {% if canSeePrices %}
                <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#attivita">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="14" x2="8.01" y2="14"/><line x1="12" y1="14" x2="12.01" y2="14"/><line x1="16" y1="14" x2="16.01" y2="14"/></svg>
                    Attività
                </button>
                <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#extra">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                    Extra
                </button>
                <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#billing">
                    <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                    Fatturazione
                </button>
            {% endif %}
        {% endif %}
        <button class="wv-tab-btn" data-bs-toggle="tab" data-bs-target="#disegni">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            Disegni
        </button>
    </div>

    <div class="tab-content wv-tabs-content">

        {% if not isWorker %}

        {# ════════════════════════════════════════════════════════════
           TAB: Presenze (Nostri)
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade show active" id="presenze" role="tabpanel">
            <div class="flex justify-end mb-3">
                <a href="/attendance/create?cantiere_id={{ worksite_id }}"
                   class="btn btn-primary text-sm px-4 py-2">
                    <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Aggiungi Presenza
                </a>
            </div>

            <div class="flex flex-row gap-2">
                <!-- Colonna Date (filtri) -->
                <div class="flex flex-col gap-2 min-w-[100px] border p-2 rounded-md shadow-sm bg-white date-scrollbar" style="max-height: 600px; overflow-y: auto;">
                    <button type="button" class="date-filter-btn" data-filter-date="all">Vedi Tutto</button>
                    {% for date in dateList %}
                        <button type="button" class="date-filter-btn" data-filter-date="{{ date }}">
                            {{ date|date('d/m/Y') }}
                        </button>
                    {% endfor %}
                </div>

                <!-- Tabella Presenze Nostri -->
                <div class="w-full overflow-x-auto">
                    <table class="table table-sm table-striped">
                        <div class="mb-3">
                            <input type="text" id="searchInput" placeholder="Cerca nelle presenze..." class="form-control w-full max-w-sm" style="padding: 8px; border: 1px solid #e5e7eb; border-radius: 6px;">
                        </div>
                        <thead>
                        <tr>
                            <th>Data</th>
                            <th>Operaio</th>
                            <th>Azienda</th>
                            <th>Turno</th>
                            <th>Pranzo</th>
                            <th>Cena</th>
                            <th>Hotel</th>
                            <th>Auto</th>
                            <th>Note</th>
                            <th class="w-40 text-center">Azioni</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% if presenze is not empty %}
                            {% for p in presenze %}
                                <tr data-date="{{ p.data }}">
                                    <td class="table-report__action w-56">{{ p.data|date('d/m/Y') }}</td>
                                    <td class="table-report__action w-40 max-w-[150px] truncate">{{ p.lavoratore }}</td>
                                    <td class="table-report__action w-40 max-w-[150px] truncate">{{ p.azienda }}</td>
                                    <td class="table-report__action w-56">{{ p.turno }}</td>
                                    <td class="table-report__action w-56">
                                        {% if p.pranzo == 'Noi' and p.pranzo_prezzo is not null and p.pranzo_prezzo != '' %}
                                            {{ p.pranzo_prezzo|number_format(2, ',', '') }} €
                                        {% else %}
                                            {{ p.pranzo }}
                                        {% endif %}
                                    </td>
                                    <td class="table-report__action w-56">
                                        {% if p.cena == 'Noi' and p.cena_prezzo is not null and p.cena_prezzo != '' %}
                                            {{ p.cena_prezzo|number_format(2, ',', '') }} €
                                        {% else %}
                                            {{ p.cena }}
                                        {% endif %}
                                    </td>
                                    <td class="table-report__action w-56">{{ p.hotel }}</td>
                                    <td class="table-report__action w-56">{{ p.targa_auto }}</td>
                                    <td class="table-report__action w-56">{{ p.note }}</td>
                                    <td class="table-report__action w-56">
                                        <div class="flex justify-center items-center">
                                            <a class="flex items-center mr-3 text-blue-600"
                                               href="/attendance/create?cantiere_id={{ worksite_id }}&duplicate_date={{ p.data }}" target="_blank">
                                                <i data-lucide="copy" class="w-4 h-4 mr-1"></i> Duplica
                                            </a>
                                            <a class="flex items-center mr-3"
                                               href="/attendance/edit?cantiere={{ worksite_id }}&data={{ p.data }}" target="_blank">
                                                <i data-lucide="check-square" class="w-4 h-4 mr-1"></i> Modifica
                                            </a>
                                            <form method="POST"
                                                  action="/worksites/{{ worksite_id }}/presenza/{{ p.id }}/delete"
                                                  data-confirm="Confermi eliminazione di questa presenza?"
                                                  class="inline-block">
                                                <button type="submit" class="flex items-center text-danger">
                                                    <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Elimina
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr><td colspan="10" class="text-center text-slate-500">Nessuna presenza registrata.</td></tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {# ════════════════════════════════════════════════════════════
           TAB: Presenze Consorziate
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade" id="presenze_cons" role="tabpanel">
            <div class="flex justify-end mb-3">
                <a href="/attendance/create?type=consorziata&cantiere_id={{ worksite_id }}"
                   class="btn btn-primary text-sm px-4 py-2">
                    <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Aggiungi Presenza Consorziata
                </a>
            </div>

            <div class="flex flex-row gap-2">
                <!-- Colonna Date (filtri) -->
                <div class="flex flex-col gap-2 min-w-[100px] border p-2 rounded-md shadow-sm bg-white date-scrollbar-cons" style="max-height: 600px; overflow-y: auto;">
                    <button type="button" class="date-filter-btn" data-filter-date="all">Vedi Tutto</button>
                    {% for date in dateListCons %}
                        <button type="button" class="date-filter-btn" data-filter-date="{{ date }}">
                            {{ date|date('d/m/Y') }}
                        </button>
                    {% endfor %}
                </div>

                <!-- Tabella Presenze Consorziate -->
                <div class="w-full overflow-x-auto">
                    <div class="mb-3 w-full">
                        <input type="text" id="searchInputCons" placeholder="Cerca nelle presenze consorziate..." class="form-control w-full max-w-sm" style="padding: 8px; border: 1px solid #e5e7eb; border-radius: 6px;">
                    </div>
                    <table class="table table-sm table-striped">
                        <thead>
                        <tr>
                            <th>Data</th>
                            <th>Consorziata</th>
                            <th>N. Operai</th>
                            <th>Costo/P</th>
                            <th>Totale</th>
                            <th>Pasti</th>
                            <th>Auto</th>
                            <th>Hotel</th>
                            <th>Note</th>
                            <th class="w-40 text-center">Azioni</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% if presenzeCons is not empty %}
                            {% for c in presenzeCons %}
                                {# Compute quantity display: integer if whole number, else 1 decimal #}
                                {% set qta = c.quantita == c.quantita|round(0) ? c.quantita|round(0) : c.quantita|number_format(1, ',', '.') %}
                                {% set totale = c.costo_unitario * c.quantita %}
                                <tr data-date="{{ c.data_presenza }}">
                                    <td class="table-report__action w-56">{{ c.data_presenza|date('d/m/Y') }}</td>
                                    <td class="table-report__action w-40 max-w-[150px] truncate">{{ c.consorziata_name }}</td>
                                    <td class="table-report__action w-56">{{ qta }}</td>
                                    <td class="table-report__action w-56">{{ c.costo_unitario|number_format(2) }} €</td>
                                    <td class="table-report__action w-56">{{ totale|number_format(2, ',', '.') }} €</td>
                                    <td class="table-report__action w-56">{{ c.pasti|number_format(2, ',', '.') }} €</td>
                                    <td class="table-report__action w-56">{{ c.auto }}</td>
                                    <td class="table-report__action w-56">{{ c.hotel }}</td>
                                    <td class="table-report__action w-56">{{ c.note }}</td>
                                    <td class="table-report__action w-56">
                                        <div class="flex justify-center items-center">
                                            <a class="flex items-center mr-3 text-blue-600"
                                               href="/attendance/create?cantiere_id={{ worksite_id }}&duplicate_date={{ c.data_presenza }}" target="_blank">
                                                <i data-lucide="copy" class="w-4 h-4 mr-1"></i> Duplica
                                            </a>
                                            <a class="flex items-center mr-3"
                                               href="/attendance/edit?cantiere={{ worksite_id }}&data={{ c.data_presenza }}" target="_blank">
                                                <i data-lucide="check-square" class="w-4 h-4 mr-1"></i> Modifica
                                            </a>
                                            <form action="/worksites/{{ worksite_id }}/presenza-consorziata/{{ c.id }}/delete"
                                                  method="POST"
                                                  data-confirm="Confermi eliminazione di questa presenza consorziata?"
                                                  class="inline-block">
                                                <button type="submit" class="flex items-center text-danger">
                                                    <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Elimina
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr><td colspan="10" class="text-center text-slate-500">Nessuna presenza consorziata.</td></tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {# ════════════════════════════════════════════════════════════
           TAB: Ordini
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade" id="ordini" role="tabpanel">
            {% if canSeePrices %}
            <div class="flex justify-end mb-3">
                <a href="/ordini/create?worksite_id={{ worksite_id }}" class="btn btn-primary text-sm px-4 py-2">
                    <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Aggiungi Ordine
                </a>
            </div>
            {% endif %}

            <div class="w-full overflow-x-auto">
                <table class="table table-sm table-striped">
                    <thead>
                    <tr>
                        <th>Data</th>
                        <th>Azienda</th>
                        {% if canSeePrices %}<th>Totale</th>{% endif %}
                        <th>Note</th>
                        {% if canSeePrices %}<th class="w-40 text-center">Azioni</th>{% endif %}
                    </tr>
                    </thead>
                    <tbody>
                    {% if ordini is not empty %}
                        {% for ordine in ordini %}
                        {% set isModulo = ordine.order_number is not null and ordine.order_number > 0 %}
                            <tr>
                                <td>{{ ordine.order_date|date('d/m/Y') }}</td>
                                <td>
                                    {{ ordine.company_name }}
                                    {% if isModulo %}
                                        <span style="display:inline-flex;align-items:center;font-size:10px;font-weight:600;color:#1e3a5f;background:#e8eef7;border-radius:5px;padding:2px 7px;margin-left:6px;">n° {{ ordine.order_number }}</span>
                                    {% endif %}
                                </td>
                                {% if canSeePrices %}
                                    <td class="{{ ordine.total >= 0 ? 'text-success' : 'text-danger' }}">
                                        {{ ordine.total|number_format(2, ',', '.') }} €
                                    </td>
                                {% endif %}
                                <td>{{ ordine.note }}</td>
                                {% if canSeePrices %}
                                <td>
                                    <div class="flex justify-center items-center">
                                        {% if isModulo %}
                                            <a href="/ordini/{{ ordine.id }}" class="flex items-center mr-3">
                                                <i data-lucide="eye" class="w-4 h-4 mr-1"></i> Visualizza
                                            </a>
                                        {% else %}
                                            <button class="flex items-center mr-3 edit-ordine-btn"
                                                    data-id="{{ ordine.id }}"
                                                    data-date="{{ ordine.order_date }}"
                                                    data-company="{{ ordine.company_id }}"
                                                    data-company-name="{{ ordine.company_name }}"
                                                    data-total="{{ ordine.total }}"
                                                    data-note="{{ ordine.note }}"
                                                    data-tw-toggle="modal"
                                                    data-tw-target="#ordine-modal">
                                                <i data-lucide="edit" class="w-4 h-4 mr-1"></i> Modifica
                                            </button>
                                            <form method="POST" action="/worksites/{{ worksite_id }}/ordine/{{ ordine.id }}/delete" class="inline-block"
                                                  data-confirm="Eliminare questo ordine?">
                                                <button type="submit" class="flex items-center text-danger">
                                                    <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i> Elimina
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="4" class="text-center text-slate-500">Nessun ordine registrato.</td></tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <!-- Modal Add/Edit Ordine -->
            <div id="ordine-modal" class="modal" tabindex="-1" aria-hidden="true" data-tw-backdrop="static" data-tw-keyboard="false">
                <div class="modal-dialog" style="max-width: 600px;">
                    <form method="POST" action="/worksites/{{ worksite_id }}/ordine" class="modal-content">
                        <div class="modal-header">
                            <h2 class="font-medium text-base mr-auto" id="ordine-modal-title">Aggiungi / Modifica Ordine</h2>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="id" id="ordine-id">
                            <input type="hidden" name="worksite_id" value="{{ worksite_id }}">
                            <div class="mb-3">
                                <label class="form-label">Data</label>
                                <input type="date" class="form-control" name="order_date" id="ordine-date" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Azienda</label>
                                <select name="company_id" id="ordine-company" required></select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Totale (€)</label>
                                <input type="number" step="0.01" class="form-control" name="total" id="ordine-total" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Note</label>
                                <textarea class="form-control" name="note" id="ordine-note"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer text-right">
                            <button type="button" data-tw-dismiss="modal" class="btn btn-outline-secondary w-20 mr-2">Chiudi</button>
                            <button type="submit" class="btn btn-primary w-20">Salva</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {# ════════════════════════════════════════════════════════════
           TAB: Mezzi
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade" id="mezzi" role="tabpanel">
            <div class="flex justify-end mb-3">
                <a href="/equipment/assign?worksite_id={{ worksite_id }}" class="btn btn-primary text-sm px-4 py-2">
                    <i data-lucide="plus" class="w-4 h-4 mr-1"></i> Assegna Mezzo
                </a>
            </div>

            <div class="w-full overflow-x-auto">
                <table class="table table-sm table-striped">
                    <thead>
                    <tr>
                        <th>Mezzo</th>
                        <th>Tipo Noleggio</th>
                        <th>Quantità</th>
                        <th>Costo €</th>
                        <th>Data Inizio</th>
                        <th>Data Fine</th>
                        <th>Stato</th>
                        <th class="w-40 text-center">Azioni</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if mezzi is not empty %}
                        {% for m in mezzi %}
                            <tr>
                                <td>{{ m.mezzo_descrizione }}</td>
                                <td>{{ m.tipo_noleggio }}</td>
                                <td>{{ m.quantita|round(0) }}</td>
                                <td>{{ m.costo_giornaliero|number_format(2, ',', '.') }} €</td>
                                <td>{{ m.data_inizio|date('d/m/Y') }}</td>
                                <td>{{ m.data_fine ? m.data_fine|date('d/m/Y') : '-' }}</td>
                                <td>
                                    {% if m.tipo_noleggio == 'Una Tantum' %}
                                        <span class="badge bg-secondary">Servizio</span>
                                    {% elseif m.stato == 'Attivo' %}
                                        <span class="badge bg-success">Attivo</span>
                                    {% elseif m.stato == 'Completato' %}
                                        <span class="badge bg-info">Completato</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ m.stato }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="flex justify-center items-center">
                                        <a class="flex items-center mr-3"
                                           href="/equipment/rentals/{{ worksite_id }}/edit?id={{ m.id }}">
                                            <i data-lucide="edit" class="w-4 h-4 mr-1"></i> Modifica
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="8" class="text-center text-slate-500">Nessun mezzo assegnato.</td></tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

        {# ════════════════════════════════════════════════════════════
           TAB: Statistiche
           NOTE: statsSummary, yardStatsRow, lavoratori, pasti, hotel,
                 stats, costiBreakdown are pre-computed and passed from controller.
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade" id="stats" role="tabpanel">

            {% if yardStatsRow %}
                <div class="alert alert-warning mb-4">
                    <strong>!!! Attenzione:</strong>
                    questo cantiere include <strong>dati storici 2025 importati da Yard</strong>.
                    I valori mostrati sono la somma dei dati BOB + Yard.
                </div>
            {% endif %}

            <div class="grid grid-cols-12 gap-4 mb-6">
                {% if canSeePrices %}
                <div class="col-span-12 sm:col-span-6 xl:col-span-3 box p-4 border-l-4 border-primary">
                    <div class="text-slate-500 text-xs uppercase">Giorni lavorati</div>
                    <div class="text-2xl font-semibold">{{ statsSummary.giorni_lavorati }}</div>
                </div>
                <div class="col-span-12 sm:col-span-6 xl:col-span-3 box p-4 border-l-4 border-success">
                    {% if statsSummary.is_consuntivo %}
                        <div class="text-slate-500 text-xs uppercase">Ricavo stimato</div>
                        <div class="text-2xl font-semibold">€ {{ statsSummary.ricavo_stimato|number_format(2, ',', '.') }}</div>
                        <div style="font-size:11px;color:#94a3b8;margin-top:4px;">€ {{ statsSummary.prezzo_persona|number_format(2, ',', '.') }}/gg · {{ statsSummary.lavoratori_totale }} gg-pers.</div>
                    {% else %}
                        <div class="text-slate-500 text-xs uppercase">Totale Contratto</div>
                        <div class="text-2xl font-semibold">€ {{ statsSummary.fatturato|number_format(2, ',', '.') }}</div>
                    {% endif %}
                </div>
                <div class="col-span-12 sm:col-span-6 xl:col-span-3 box p-4 border-l-4 border-warning">
                    <div class="text-slate-500 text-xs uppercase">Costi totali</div>
                    <div class="text-2xl font-semibold">€ {{ statsSummary.costo_totale|number_format(2, ',', '.') }}</div>
                </div>
                <div class="col-span-12 sm:col-span-6 xl:col-span-3 box p-4 border-l-4 {{ margin >= 0 ? 'border-success' : 'border-danger' }}">
                    <div class="text-slate-500 text-xs uppercase">Andamento</div>
                    <div class="text-2xl font-semibold {{ margin >= 0 ? 'text-success' : 'text-danger' }}">
                        € {{ margin|number_format(2, ',', '.') }}
                    </div>
                </div>
                {% endif %}
            </div>

            <div class="grid grid-cols-12 gap-6 mb-6">
                <div class="col-span-12 xl:col-span-6 box p-4">
                    <h3 class="font-medium mb-3">Presenze</h3>
                    <table class="table table-sm">
                        <tbody>
                        <tr>
                            <td>Operai interni</td>
                            <td class="text-right font-medium">{{ statsSummary.lavoratori_nostri }}</td>
                        </tr>
                        <tr>
                            <td>Consorziate</td>
                            <td class="text-right font-medium">{{ statsSummary.lavoratori_consorziate }}</td>
                        </tr>
                        <tr class="font-semibold border-t">
                            <td>Totale Operai</td>
                            <td class="text-right">{{ statsSummary.lavoratori_totale }}</td>
                        </tr>
                        </tbody>
                    </table>
                    <br>
                    <h3 class="font-medium mb-3">Pasti</h3>
                    <table class="table table-sm">
                        <thead>
                        <tr class="text-slate-500 text-xs uppercase">
                            <th>Voce</th>
                            <th class="text-right">Quantità</th>
                            <th class="text-right">Importo (€)</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td>Pagati da noi</td>
                            <td class="text-right">{{ statsSummary.pasti_noi_qta }}</td>
                            <td class="text-right">€ {{ statsSummary.pasti_noi_euro|number_format(2, ',', '.') }}</td>
                        </tr>
                        <tr>
                            <td>Pagati da loro</td>
                            <td class="text-right">{{ statsSummary.pasti_loro_qta }}</td>
                            <td class="text-right">€ {{ statsSummary.pasti_loro_euro|number_format(2, ',', '.') }}</td>
                        </tr>
                        </tbody>
                        <tfoot>
                        <tr class="font-semibold border-t">
                            <td>Totale pasti</td>
                            <td class="text-right">{{ statsSummary.pasti_totale_qta }}</td>
                            <td class="text-right">€ {{ statsSummary.pasti_totale_euro|number_format(2, ',', '.') }}</td>
                        </tr>
                        </tfoot>
                    </table>
                    <br>
                    <h3 class="font-medium mb-3">Hotel</h3>
                    <table class="table table-sm">
                        <thead>
                        <tr class="text-slate-500 text-xs uppercase">
                            <th>Voce</th>
                            <th class="text-right">Persone</th>
                            <th class="text-right">Importo (€)</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td>Operai interni</td>
                            <td class="text-right">{{ statsSummary.hotel_nostri_qta }}</td>
                            <td class="text-right">€ {{ statsSummary.hotel_nostri_euro|number_format(2, ',', '.') }}</td>
                        </tr>
                        <tr>
                            <td>Consorziate</td>
                            <td class="text-right">{{ statsSummary.hotel_consorziate_qta }}</td>
                            <td class="text-right">€ {{ statsSummary.hotel_consorziate_euro|number_format(2, ',', '.') }}</td>
                        </tr>
                        </tbody>
                        <tfoot>
                        <tr class="font-semibold border-t">
                            <td>Totale</td>
                            <td class="text-right">{{ statsSummary.hotel_totale_qta }}</td>
                            <td class="text-right">€ {{ statsSummary.hotel_totale_euro|number_format(2, ',', '.') }}</td>
                        </tr>
                        </tfoot>
                    </table>
                </div>

                {% if canSeePrices %}
                <div class="col-span-12 xl:col-span-6 box p-4">
                    <h3 class="font-medium mb-3">Dettaglio costi</h3>
                    <table class="table table-sm">
                        <tbody>
                        {% for c in statsSummary.costi_breakdown %}
                            <tr>
                                <td>{{ c.voce }}</td>
                                <td class="text-right">€ {{ c.importo|number_format(2, ',', '.') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                        <tfoot>
                        <tr class="font-semibold border-t">
                            <td>Totale</td>
                            <td class="text-right">€ {{ statsSummary.costo_totale|number_format(2, ',', '.') }}</td>
                        </tr>
                        </tfoot>
                    </table>
                </div>
                {% endif %}
            </div>

        </div>

        {# ════════════════════════════════════════════════════════════
           TAB: Assistente AI
           ════════════════════════════════════════════════════════════ #}
        <div class="tab-pane fade" id="ai" role="tabpanel">
        <div class="box p-5 mt-3">

            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center">
                        <i data-lucide="bot" class="w-5 h-5 text-primary"></i>
                    </div>
                    <div>
                        <h3 class="font-semibold text-base leading-none">BOB AI</h3>
                        <p class="text-xs text-slate-400 mt-0.5">Assistente del cantiere</p>
                    </div>
                </div>
                <span class="flex items-center gap-1.5 text-xs text-emerald-500">
                    <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                    Online
                </span>
            </div>

            <!-- Suggested Questions -->
            <div class="mb-4">
                <p class="text-xs text-slate-400 uppercase font-semibold tracking-wide mb-2">Domande rapide</p>
                <div class="flex flex-wrap gap-1.5">
                    <button class="ai-chip"  data-q="Quante presenze totali? Nostri e consorziati, e dettaglio per lavoratore.">
                        <i data-lucide="users" class="w-3 h-3"></i> Presenze totali
                    </button>
                    <button class="ai-chip"  data-q="Quanti giorni lavorati e quando è stata l'ultima presenza?">
                        <i data-lucide="calendar" class="w-3 h-3"></i> Giorni lavorati
                    </button>
                    <button class="ai-chip"  data-q="Chi ha lavorato di più in questo cantiere? Mostra i top 5 lavoratori con giornate e periodo.">
                        <i data-lucide="hard-hat" class="w-3 h-3"></i> Top lavoratori
                    </button>
                    <button class="ai-chip"  data-q="Riepilogo presenze per mese: quanti giorni, nostri e consorziati per ogni mese.">
                        <i data-lucide="bar-chart-2" class="w-3 h-3"></i> Presenze per mese
                    </button>
                    <button class="ai-chip"  data-q="Quali aziende consorziate hanno lavorato qui? Quante giornate ciascuna?">
                        <i data-lucide="building" class="w-3 h-3"></i> Consorziate
