    {# CSP-compliant nonce-tagged script: confirm dialogs + AI chat #}
    <script nonce="{{ cspNonce }}">
    (function () {
        'use strict';

        // ── Confirm dialogs on forms with data-confirm ──────────────────────
        document.addEventListener('submit', function (e) {
            var msg = e.target.getAttribute('data-confirm');
            if (msg && !window.confirm(msg)) {
                e.preventDefault();
            }
        });

        // ── BOB AI chat ─────────────────────────────────────────────────────
        var WID = {{ worksite_id|e('js') }};

        function aiAppend(role, text) {
            var chat = document.getElementById('ai-chat');
            if (!chat) return;
            var empty = document.getElementById('ai-empty');
            if (empty) empty.remove();

            var wrap   = document.createElement('div');
            wrap.className = 'flex items-end gap-2 ' + (role === 'Tu' ? 'justify-end' : 'justify-start');

            var avatar = document.createElement('div');
            avatar.className = 'w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold flex-shrink-0 ' +
                (role === 'Tu' ? 'bg-primary text-white' : 'bg-slate-300 text-slate-700');
            avatar.textContent = role === 'Tu' ? 'TU' : 'AI';

            var bubble = document.createElement('div');
            bubble.className = 'max-w-[75%] px-4 py-3 rounded-2xl text-sm leading-relaxed shadow-sm ' +
                (role === 'Tu'
                    ? 'bg-primary text-white rounded-br-sm'
                    : 'bg-white border border-slate-200 text-slate-700 rounded-bl-sm');
            bubble.innerHTML = text.replace(/\n/g, '<br>');

            if (role === 'Tu') { wrap.appendChild(bubble); wrap.appendChild(avatar); }
            else               { wrap.appendChild(avatar); wrap.appendChild(bubble); }

            chat.appendChild(wrap);
            chat.scrollTop = chat.scrollHeight;
        }

        function aiSetLoading(state) {
            var send = document.getElementById('ai-send');
            var st   = document.getElementById('ai-status');
            if (send) send.disabled = state;
            if (st)   st.textContent = state ? 'BOB AI sta elaborando…' : '';
        }

        async function aiAsk(question) {
            if (!question) {
                var inp = document.getElementById('ai-question');
                question = inp ? inp.value.trim() : '';
            }
            if (!question) return;

            var inp = document.getElementById('ai-question');
            if (inp) inp.value = '';
            aiAppend('Tu', question);
            aiSetLoading(true);

            try {
                var fd = new FormData();
                fd.append('worksite_id', WID);
                fd.append('question', question);

                var res  = await fetch('/worksites/ask-ai', { method: 'POST', body: fd });
                var data = await res.json();

                aiAppend('BOB AI', data.ok ? (data.answer || 'Nessuna risposta.') : (data.error || 'Errore durante l\'elaborazione.'));
            } catch (err) {
                aiAppend('BOB AI', 'Errore di rete. Riprova.');
            }
            aiSetLoading(false);
        }

        window.aiAsk = aiAsk;

        document.addEventListener('click', function (e) {
            // AI chip buttons
            var chip = e.target.closest('.ai-chip');
            if (chip) { aiAsk(chip.dataset.q); return; }

            // AI send button
            if (e.target.closest('#ai-send')) { aiAsk(); return; }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && e.target.id === 'ai-question') {
                e.preventDefault();
                aiAsk();
            }
        });
    })();
    </script>
{% endblock %}
