                    <button class="ai-chip"  data-q="Riepilogo completo del cantiere: presenze, lavoratori, mezzi, stato generale.">
                        <i data-lucide="file-text" class="w-3 h-3"></i> Riepilogo
                    </button>
                </div>
            </div>

            <!-- Chat Area -->
