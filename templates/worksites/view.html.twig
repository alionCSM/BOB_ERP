                    <button class="ai-chip"  data-q="Quali mezzi ci sono in cantiere? Per ognuno dimmi da quando è presente e lo stato.">
                        <i data-lucide="hard-hat" class="w-3 h-3"></i> Mezzi in cantiere
                    </button>
                    {% if canSeePrices %}
                    <button class="ai-chip"  data-q="Riepilogo economico completo: ricavi (contratto + extra), dettaglio costi per voce, e margine.">
                        <i data-lucide="euro" class="w-3 h-3"></i> Economia
                    </button>
                    <button class="ai-chip"  data-q="Quanto è costato finora ogni mezzo? E quanto costano le consorziate per azienda?">
                        <i data-lucide="calculator" class="w-3 h-3"></i> Dettaglio costi
                    </button>
                    <button class="ai-chip"  data-q="Totale fatturato, quanti documenti di fatturazione, e lista ordini con importi.">
                        <i data-lucide="banknote" class="w-3 h-3"></i> Fatturazione
                    </button>
