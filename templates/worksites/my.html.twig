{% extends 'layout/base.html.twig' %}

{% block content %}
<div class="intro-y box p-5 mt-5">
    <h2 class="font-medium text-lg mb-4">Cantieri assegnati</h2>

    {% if worksites is empty %}
        <div class="text-slate-500">
            Nessun cantiere assegnato.
        </div>
    {% else %}

        <!-- ===================== -->
        <!-- DESKTOP TABLE -->
        <!-- ===================== -->
        <div class="hidden md:block">
            <table class="table table-report">
                <thead>
                <tr>
                    <th>Nome</th>
                    <th>Codice</th>
                    <th>Località</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for w in worksites %}
                    <tr>
                        <td class="font-medium">{{ w.name }}</td>
                        <td>{{ w.worksite_code }}</td>
                        <td>{{ w.location }}</td>
                        <td class="text-right">
                            <a href="/worksites/{{ w.id }}" class="btn btn-sm btn-primary">
                                Apri
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- ===================== -->
        <!-- MOBILE CARDS -->
        <!-- ===================== -->
        <div class="space-y-4 md:hidden">
            {% for w in worksites %}
                <div class="border rounded-lg p-4 bg-white shadow-sm">
                    <div class="font-medium text-base">{{ w.name }}</div>
                    <div class="text-slate-500 text-sm mt-1">Codice: {{ w.worksite_code }}</div>
                    <div class="text-slate-500 text-sm">{{ w.location }}</div>
                    <div class="mt-3">
                        <a href="/worksites/{{ w.id }}" class="btn btn-primary w-full">
                            Apri cantiere
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>

    {% endif %}
</div>
{% endblock %}
