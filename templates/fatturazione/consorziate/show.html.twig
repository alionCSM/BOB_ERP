{% extends "layout/base.html.twig" %}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/fatturazione/consorziate_show.css">
{% endblock %}

{% block content %}
<div class="fp-page">

    {# ── Hero ── #}
    <div class="fp-hero">
        <div class="fp-hero-content">
            <div class="fp-hero-left">
                <div class="fp-hero-icon">
                    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div>
                    <p class="fp-hero-breadcrumb">
                        <a href="/fatturazione/consorziate">Pagamenti Consorziate</a>
                        <span style="opacity:.4; margin:0 4px;">›</span>
                        {{ consorziata.name }}
                    </p>
                    <h1 class="fp-hero-title">{{ consorziata.name }}</h1>
                    <p class="fp-hero-period">Periodo: <strong>{{ fromLabel }}</strong> – <strong>{{ toLabel }}</strong></p>
                </div>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
                {% if rows is not empty %}
                <a href="/fatturazione/consorziate/{{ consorziata.id }}/export?from={{ from }}&to={{ to }}"
                   class="fp-btn-period" style="background:#16a34a; border-color:#16a34a; text-decoration:none;">
                    <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Esporta Excel
                </a>
                {% endif %}
                <button type="button" class="fp-btn-period" data-tw-toggle="modal" data-tw-target="#period-modal">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Cambia periodo
                </button>
            </div>
        </div>
    </div>

    {# ── Stats ── #}
    {% set residuoTot = totalOrdine - totalGiaPagato - totalSpese %}
    <div class="fp-stats">
        <div class="fp-stat">
            <div class="fp-stat-dot" style="background:#3b82f6;"></div>
            <div>
                <div class="fp-stat-value">{{ totalPresenze|number_format(1, ',', '.') }}</div>
                <div class="fp-stat-label">Presenze (gg)</div>
                <div class="fp-stat-sub">nel periodo</div>
            </div>
        </div>
        <div class="fp-stat">
            <div class="fp-stat-dot" style="background:#f97316;"></div>
            <div>
                <div class="fp-stat-value">€ {{ totalCosto|number_format(0, ',', '.') }}</div>
                <div class="fp-stat-label">Costo presenze</div>
                <div class="fp-stat-sub">nel periodo</div>
            </div>
        </div>
        <div class="fp-stat">
            <div class="fp-stat-dot" style="background:#8b5cf6;"></div>
            <div>
                <div class="fp-stat-value">€ {{ totalOrdine|number_format(0, ',', '.') }}</div>
                <div class="fp-stat-label">Valore ordini</div>
                <div class="fp-stat-sub">cantieri nel periodo</div>
            </div>
        </div>
        <div class="fp-stat">
            <div class="fp-stat-dot" style="background:#22c55e;"></div>
            <div>
                <div class="fp-stat-value">€ {{ totalStorico|number_format(0, ',', '.') }}</div>
                <div class="fp-stat-label">Totale pagato</div>
                <div class="fp-stat-sub">storico completo</div>
            </div>
        </div>
        {% if totalSpese > 0 %}
        <div class="fp-stat">
            <div class="fp-stat-dot" style="background:#f43f5e;"></div>
            <div>
                <div class="fp-stat-value danger">€ {{ totalSpese|number_format(0, ',', '.') }}</div>
                <div class="fp-stat-label">Spese a loro carico</div>
                <div class="fp-stat-sub">prenotazioni nel periodo</div>
            </div>
        </div>
        {% endif %}
        <div class="fp-stat">
            <div class="fp-stat-dot" style="background:{% if residuoTot < 0 %}#dc2626{% elseif residuoTot == 0 %}#94a3b8{% else %}#0ea5e9{% endif %};"></div>
            <div>
                <div class="fp-stat-value{% if residuoTot < 0 %} danger{% elseif residuoTot == 0 %}{% else %}{% endif %}">
                    € {{ residuoTot|number_format(0, ',', '.') }}
                </div>
                <div class="fp-stat-label">Residuo</div>
                <div class="fp-stat-sub">ordini – già pagato</div>
            </div>
        </div>
    </div>

    {# ── Payment form ── #}
    <form id="payment-form" method="POST" action="/fatturazione/consorziate/{{ consorziata.id }}/pay">
        <input type="hidden" name="from" value="{{ from }}">
        <input type="hidden" name="to"   value="{{ to }}">

        <div class="fp-section">
            <div class="fp-section-header">
                <h2 class="fp-section-title">
                    <span class="fp-section-dot" style="background:#3b82f6;"></span>
                    Cantieri nel periodo
                    <span class="fp-section-count">({{ rows|length }})</span>
                </h2>
            </div>

            {% if rows is empty %}
                <div class="fp-table-wrap">
                    <div class="fp-empty">
                        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
                        <p class="fp-empty-text">
                            Nessuna presenza registrata per <strong>{{ consorziata.name }}</strong> nel periodo selezionato.
                        </p>
                    </div>
                </div>
            {% else %}
                <div class="fp-table-wrap">
                    <div style="overflow-x:auto;">
                        <table class="fp-table" id="detail-table">
                            <thead>
                                <tr>
                                    <th>Cantiere</th>
                                    <th class="right">Presenze (gg)</th>
                                    <th class="right">Costo presenze</th>
                                    <th class="right">Valore ordine</th>
                                    <th class="right">Data ordine</th>
                                    <th class="right">Già pagato</th>
                                    <th class="right">Spese a carico</th>
                                    <th class="right">Residuo</th>
                                    <th style="min-width:170px;">Ordine da pagare</th>
                                    <th class="right" style="min-width:150px;">Da pagare (€)</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for r in rows %}
                                <tr class="detail-row"
                                    data-valore="{{ r.valore_ordine }}"
                                    data-pagato="{{ r.gia_pagato }}"
                                    data-spese="{{ r.spese_consorziata }}">
                                    <td>
                                        <input type="hidden" name="worksite_id[]" value="{{ r.worksite_id }}">
                                        <a href="/worksites/{{ r.worksite_id }}" class="fp-link" target="_blank">
                                            {% if r.worksite_code %}<span class="fp-code">{{ r.worksite_code }}</span>{% endif %}
                                            {{ r.worksite_name }}
                                        </a>
                                    </td>
                                    <td class="right">{{ r.presenze_gg|number_format(2, ',', '.') }}</td>
                                    <td class="right">€ {{ r.costo_presenze|number_format(2, ',', '.') }}</td>
                                    <td class="right">
                                        {% if r.valore_ordine > 0 %}
                                            € {{ r.valore_ordine|number_format(2, ',', '.') }}
                                        {% else %}
                                            <span class="fp-dash">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="right" style="white-space:nowrap;">
                                        {% if r.data_ordine %}
                                            {{ r.data_ordine|date('d/m/Y') }}
                                        {% else %}
                                            <span class="fp-dash">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="right">
                                        {% if r.gia_pagato > 0 %}
                                            <span class="fp-success">€ {{ r.gia_pagato|number_format(2, ',', '.') }}</span>
                                        {% else %}
                                            <span class="fp-dash">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="right">
                                        {% if r.spese_consorziata > 0 %}
                                            <span class="fp-danger">€ {{ r.spese_consorziata|number_format(2, ',', '.') }}</span>
                                        {% else %}
                                            <span class="fp-dash">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="right fc-residuo">
                                        {% set residuo = r.valore_ordine - r.gia_pagato - r.spese_consorziata %}
                                        <span class="{{ residuo < 0 ? 'fp-danger' : (residuo == 0 ? 'fp-muted' : '') }}">
                                            € {{ residuo|number_format(2, ',', '.') }}
                                        </span>
                                    </td>
                                    <td>
                                        {% set wsOrdini = ordiniByWorksite[r.worksite_id] ?? [] %}
                                        <select name="ordine_id[]" class="fp-input">
                                            <option value="">— nessuno —</option>
                                            {% for o in wsOrdini %}
                                                <option value="{{ o.id }}"{{ wsOrdini|length == 1 ? ' selected' : '' }}>
                                                    {{ o.order_number ?: ('Ordine #' ~ o.id) }}
                                                    {% if o.order_date %} · {{ o.order_date|date('d/m/Y') }}{% endif %}
                                                    {% if o.total %} · € {{ o.total|number_format(0, ',', '.') }}{% endif %}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </td>
                                    <td class="right">
                                        <input type="number"
                                               name="importo[]"
                                               class="fp-input fc-importo-input"
                                               step="0.01"
                                               min="0"
                                               placeholder="0,00"
                                               autocomplete="off">
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td class="right fp-muted" colspan="2">Totali</td>
                                    <td class="right">€ {{ totalCosto|number_format(2, ',', '.') }}</td>
                                    <td class="right">€ {{ totalOrdine|number_format(2, ',', '.') }}</td>
                                    <td class="right"></td>
                                    <td class="right">€ {{ totalGiaPagato|number_format(2, ',', '.') }}</td>
                                    <td class="right">{% if totalSpese > 0 %}<span class="fp-danger">€ {{ totalSpese|number_format(2, ',', '.') }}</span>{% else %}—{% endif %}</td>
                                    <td class="right" id="tot-residuo"></td>
                                    <td></td>
                                    <td class="right" id="tot-da-pagare">—</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    {# ── Save bar ── #}
                    <div class="fp-save-bar">
                        <div>
                            <label class="fp-save-bar-label">Data pagamento <span style="color:#dc2626;">*</span></label>
                            <input type="date" id="data_pagamento" name="data_pagamento"
                                   value="{{ "now"|date("Y-m-d") }}" required>
                        </div>
                        <div class="fp-save-bar-note">
                            <label class="fp-save-bar-label">Note</label>
                            <input type="text" name="nota" placeholder="Note opzionali…">
                        </div>
                        <div>
                            <button type="submit" id="save-btn" class="fp-btn-save" disabled>
                                <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17,21 17,13 7,13 7,21"/><polyline points="7,3 7,8 15,8"/></svg>
                                Salva pagamenti
                            </button>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </form>

    {# ── Storico pagamenti ── #}
    <div class="fp-storico">
        <div class="fp-storico-header" data-action="toggle-storico">
            <h2 class="fp-storico-title">
                <span class="fp-section-dot" style="background:#22c55e; width:8px; height:8px;"></span>
                Storico Pagamenti
                <span class="fp-storico-meta">
                    ({{ payments|length }} {% if payments|length == 1 %}pagamento{% else %}pagamenti{% endif %}
                    — tot. € {{ totalStorico|number_format(2, ',', '.') }})
                </span>
            </h2>
            <svg class="fp-storico-chevron" id="storico-chevron" viewBox="0 0 24 24">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </div>

        <div id="storico-body" class="fp-storico-body{{ payments is empty ? ' hidden' : '' }}">
            {% if payments is empty %}
                <div class="fp-empty">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <p class="fp-empty-text">Nessun pagamento registrato.</p>
                </div>
            {% else %}
                <div style="overflow-x:auto;">
                    <table class="fp-table">
                        <thead>
                            <tr>
                                <th>Data</th>
                                <th>Cantiere</th>
                                <th>Ordine</th>
                                <th class="right">Importo</th>
                                <th>Note</th>
                                <th>Registrato il</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for p in payments %}
                            <tr>
                                <td style="white-space:nowrap;">{{ p.data_pagamento|date('d/m/Y') }}</td>
                                <td>
                                    {% if p.worksite_code %}<span class="fp-code">{{ p.worksite_code }}</span>{% endif %}
                                    {{ p.worksite_name }}
                                </td>
                                <td style="white-space:nowrap;">
                                    {% if p.ordine_id %}
                                        {{ p.order_number ?: ('Ordine #' ~ p.ordine_id) }}
                                        {% if p.order_date %}<span class="fp-muted" style="font-size:11px;"> · {{ p.order_date|date('d/m/Y') }}</span>{% endif %}
                                    {% else %}
                                        <span class="fp-dash">—</span>
                                    {% endif %}
                                </td>
                                <td class="right fp-success">€ {{ p.importo|number_format(2, ',', '.') }}</td>
                                <td class="fp-muted" style="font-size:12px;">{{ p.note ?? '—' }}</td>
                                <td class="fp-muted" style="font-size:12px; white-space:nowrap;">{{ p.created_at|date('d/m/Y') }}</td>
                                <td class="right">
                                    <form method="POST"
                                          action="/fatturazione/consorziate/{{ consorziata.id }}/payment/{{ p.id }}/delete"
                                          data-confirm="Eliminare il pagamento di € {{ p.importo|number_format(2, ',', '.') }}?">
                                        <input type="hidden" name="from" value="{{ from }}">
                                        <input type="hidden" name="to"   value="{{ to }}">
                                        <button type="submit" class="fp-btn-delete">
                                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="right fp-muted">Totale pagato</td>
                                <td class="right">€ {{ totalStorico|number_format(2, ',', '.') }}</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

</div>

{# ── "Cambia periodo" modal ── #}
<div id="period-modal" class="modal fade" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="font-medium text-base mr-auto">Cambia Periodo</h2>
            </div>
            <form method="GET" action="/fatturazione/consorziate/{{ consorziata.id }}">
                <div class="modal-body grid grid-cols-2 gap-4 p-5">
                    <div>
                        <label class="form-label">Dal <span class="text-danger">*</span></label>
                        <input type="date" name="from" class="form-control" value="{{ from }}" required>
                    </div>
                    <div>
                        <label class="form-label">Al <span class="text-danger">*</span></label>
                        <input type="date" name="to" class="form-control" value="{{ to }}" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary mr-2" data-tw-dismiss="modal">Annulla</button>
                    <button type="submit" class="btn btn-primary">Applica</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/assets/js/views/fatturazione/consorziate.js"></script>
{% endblock %}
