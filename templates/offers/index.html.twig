{% extends 'layout/base.html.twig' %}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/offers/offers_list.css">
{% endblock %}

{% block content %}
<div class="cfl-page">

{# Hero #}
<div class="cfl-hero">
    <div class="cfl-hero-content">
        <div class="cfl-hero-left">
            <div class="cfl-hero-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
            </div>
            <div class="cfl-hero-info">
                <h1 class="cfl-hero-title">Offerte</h1>
                <p class="cfl-hero-sub">Gestisci le tue offerte commerciali</p>
            </div>
        </div>
        <div class="cfl-hero-actions">
            <a href="/offers/create" class="cfl-btn-create">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
                Nuova Offerta
            </a>
            <div class="cfl-search-wrapper">
                <input type="text" id="search-offer" placeholder="Cerca offerta..." class="cfl-search-input">
                <svg class="cfl-search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </div>
        </div>
    </div>
</div>


{# Status filter tabs #}
<div class="cfl-status-tabs">
    <button class="cfl-status-tab active" data-status="all">Tutte</button>
    <button class="cfl-status-tab" data-status="bozza">
        <span class="cfl-badge cfl-badge-bozza">Bozza</span>
    </button>
    <button class="cfl-status-tab" data-status="inviata">
        <span class="cfl-badge cfl-badge-inviata">Inviata</span>
    </button>
    <button class="cfl-status-tab" data-status="in_trattativa">
        <span class="cfl-badge cfl-badge-in_trattativa">In Trattativa</span>
    </button>
    <button class="cfl-status-tab" data-status="approvata">
        <span class="cfl-badge cfl-badge-approvata">Approvata</span>
    </button>
    <button class="cfl-status-tab" data-status="rifiutata">
        <span class="cfl-badge cfl-badge-rifiutata">Rifiutata</span>
    </button>
    <button class="cfl-status-tab" data-status="scaduta">
        <span class="cfl-badge cfl-badge-scaduta">Scaduta</span>
    </button>
</div>

{# Offers Table #}
{% if offers is empty %}
<div class="cfl-table-wrapper">
    <div class="cfl-empty">
        <svg class="cfl-empty-icon" viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
        </svg>
        <div class="cfl-empty-title">Nessuna offerta trovata</div>
        <div class="cfl-empty-text">Inizia creando la tua prima offerta commerciale</div>
    </div>
</div>
{% else %}
<div class="cfl-table-wrapper">
    <table class="cfl-table">
        <thead>
            <tr>
                <th>N° Offerta</th>
                <th>Cliente</th>
                <th>Oggetto</th>
                <th class="text-center">Stato</th>
                <th class="text-center">Totale</th>
                <th class="text-center">Data</th>
                {% if user.companyId == 1 %}
                    <th class="text-center">Azienda</th>
                {% endif %}
                <th class="text-center">Creato da</th>
                <th class="text-center">Azioni</th>
            </tr>
        </thead>
        <tbody id="offerTable">
            {% for offer in offers %}
            <tr data-status="{{ offer.status ?? 'bozza' }}">
                <td>
                    <a href="/offers/{{ offer.id }}" class="cfl-offer-link">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                        {{ offer.offer_number }}
                    </a>
                </td>
                <td>
                    <div class="cfl-client-info">
                        <div class="cfl-client-avatar">
                            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"></path></svg>
                        </div>
                        <span class="cfl-client-name">{{ offer.client_name }}</span>
                    </div>
                </td>
                <td>
                    <div class="cfl-subject" title="{{ offer.subject }}">
                        {{ offer.subject }}
                    </div>
                </td>
                <td class="text-center">
                    <div class="cfl-status-cell" data-offer-id="{{ offer.id }}">
                        {% set s = offer.status ?? 'bozza' %}
                        <button type="button" class="cfl-badge cfl-badge-{{ s }} cfl-badge-btn" title="Cambia stato">
                            {% if s == 'bozza' %}Bozza
                            {% elseif s == 'inviata' %}Inviata
                            {% elseif s == 'in_trattativa' %}In Trattativa
                            {% elseif s == 'approvata' %}Approvata
                            {% elseif s == 'rifiutata' %}Rifiutata
                            {% elseif s == 'scaduta' %}Scaduta
                            {% else %}{{ s }}{% endif %}
                            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
                        </button>
                        <div class="cfl-status-dropdown">
                            <button type="button" data-val="bozza"><span class="cfl-badge cfl-badge-bozza">Bozza</span></button>
                            <button type="button" data-val="inviata"><span class="cfl-badge cfl-badge-inviata">Inviata</span></button>
                            <button type="button" data-val="in_trattativa"><span class="cfl-badge cfl-badge-in_trattativa">In Trattativa</span></button>
                            <button type="button" data-val="approvata"><span class="cfl-badge cfl-badge-approvata">Approvata</span></button>
                            <button type="button" data-val="rifiutata"><span class="cfl-badge cfl-badge-rifiutata">Rifiutata</span></button>
                            <button type="button" data-val="scaduta"><span class="cfl-badge cfl-badge-scaduta">Scaduta</span></button>
                        </div>
                    </div>
                </td>
                <td class="text-center">
                    <span class="cfl-amount">€ {{ offer.total_amount_float|number_format(2, ',', '.') }}</span>
                </td>
                <td class="text-center">
                    <span class="cfl-date">{{ offer.created_at|date('d/m/Y') }}</span>
                </td>
                {% if user.companyId == 1 %}
                    <td class="text-center">{{ offer.company_name }}</td>
                {% endif %}
                <td class="text-center">
                    <span class="cfl-date">{{ offer.creator_name }}</span>
                </td>
                <td class="text-center">
                    <div class="cfl-actions">
                        <a href="/offers/{{ offer.id }}" class="cfl-action-btn cfl-action-view" title="Visualizza">
                            <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </a>
                        <a href="/offers/{{ offer.id }}/revise" class="cfl-action-btn cfl-action-revise" title="Revisione">
                            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                        </a>
                        <a href="/offers/{{ offer.id }}/pdf" target="_blank" class="cfl-action-btn cfl-action-download" title="Scarica PDF">
                            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        </a>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/offers/offer_list.js"></script>
{% endblock %}
