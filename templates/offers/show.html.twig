{% extends 'layout/base.html.twig' %}

{% block head %}
<link rel="stylesheet" href="/assets/css/views/offers/offers_list.css">
<link rel="stylesheet" href="/assets/css/views/offers/offers_form.css">
<link rel="stylesheet" href="/assets/css/views/offers/offer_show.css">
{% endblock %}

{% block content %}
{% set s = offerData.status ?? 'bozza' %}
{% set statusLabels = {bozza: 'Bozza', inviata: 'Inviata', in_trattativa: 'In Trattativa', approvata: 'Approvata', rifiutata: 'Rifiutata', scaduta: 'Scaduta'} %}

<div class="cos-page">

{# Hero #}
<div class="cos-hero">
    <div class="cos-hero-left">
        <div class="cos-hero-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
        </div>
        <div class="cos-hero-info">
            <div class="cos-hero-row">
                <h1 class="cos-hero-title">Offerta {{ offerData.offer_number }}</h1>
                <span class="cfl-badge cfl-badge-{{ s }}" id="heroBadge">{{ statusLabels[s] ?? s }}</span>
            </div>
            <p class="cos-hero-sub">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                {{ offerData.client_name ?? '—' }}
                <span class="cos-hero-sep">·</span>
                <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {{ offerData.offer_date|date('d/m/Y') }}
            </p>
        </div>
    </div>
    <div class="cos-hero-actions">
        <a href="/offers" class="cfo-btn-back">
            <svg viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Lista
        </a>
        <a href="/offers/{{ offerId }}/revise" class="cos-btn-action cos-btn-revise">
            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Revisione
        </a>
        <a href="/offers/{{ offerId }}/pdf" target="_blank" class="cos-btn-action cos-btn-pdf">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Scarica PDF
        </a>
        <a href="/offers/{{ offerId }}/edit" class="cos-btn-edit">
            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Modifica
        </a>
    </div>
</div>

{# Main grid #}
<div class="cos-grid">

    {# ── Left column ── #}
    <div class="cos-left">

        {# Status selector #}
        <div class="cos-card">
            <div class="cos-card-title">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Stato Offerta
            </div>
            <div class="cfo-status-select-group" id="statusSelectGroup" data-offer-id="{{ offerId }}">
                {% for val, label in statusLabels %}
                <button type="button"
                        class="cfl-badge cfl-badge-{{ val }} cfo-status-btn {% if s == val %}active{% endif %}"
                        data-val="{{ val }}">{{ label }}</button>
                {% endfor %}
            </div>
        </div>

        {# Offer details #}
        <div class="cos-card">
            <div class="cos-card-title">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Dettagli Offerta
            </div>
            <div class="cos-details">
                <div class="cos-detail-row">
                    <span class="cos-detail-label">Cliente</span>
                    <span class="cos-detail-value">{{ offerData.client_name ?? '—' }}</span>
                </div>
                <div class="cos-detail-row">
                    <span class="cos-detail-label">Numero</span>
                    <span class="cos-detail-value">{{ offerData.offer_number }}</span>
                </div>
                <div class="cos-detail-row">
                    <span class="cos-detail-label">Data</span>
                    <span class="cos-detail-value">{{ offerData.offer_date|date('d/m/Y') }}</span>
                </div>
                {% if offerData.subject %}
                <div class="cos-detail-row">
                    <span class="cos-detail-label">Oggetto</span>
                    <span class="cos-detail-value">{{ offerData.subject }}</span>
                </div>
                {% endif %}
                {% if offerData.reference %}
                <div class="cos-detail-row">
                    <span class="cos-detail-label">Riferimento</span>
                    <span class="cos-detail-value">{{ offerData.reference }}</span>
                </div>
                {% endif %}
                {% if offerData.cortese_att %}
                <div class="cos-detail-row">
                    <span class="cos-detail-label">Att.ne</span>
                    <span class="cos-detail-value">{{ offerData.cortese_att }}</span>
                </div>
                {% endif %}
                <div class="cos-detail-row cos-detail-total">
                    <span class="cos-detail-label">Totale</span>
                    <span class="cos-detail-value cos-total-value">{{ offerData.total_amount }}</span>
                </div>
                {% if offerData.is_revision %}
                <div class="cos-detail-row">
                    <span class="cos-detail-label">Revisione di</span>
                    <span class="cos-detail-value">{{ offerData.base_offer_number }}</span>
                </div>
                {% endif %}
            </div>
        </div>

        {# Internal notes (if any) #}
        {% if offerData.note_interne %}
        <div class="cos-card cos-card-internal">
            <div class="cos-card-title">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                Note Interne
            </div>
            <p class="cos-internal-note">{{ offerData.note_interne }}</p>
            {% if offerData.doc_path %}
            <a href="/offers/{{ offerId }}/doc" target="_blank" class="cos-doc-link">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Visualizza PDF allegato
            </a>
            {% endif %}
        </div>
        {% endif %}

        {# Follow-up log #}
        <div class="cos-card">
            <div class="cos-followup-header">
                <div class="cos-card-title" style="margin-bottom:0">
                    <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .91h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                    Follow-up
                </div>
                <button type="button" class="cfo-btn-primary cfo-btn-sm" id="toggleFollowupForm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                    Aggiungi
                </button>
            </div>

            {# Add form #}
            <div class="cfo-followup-form hidden" id="followupForm" style="margin-top:14px">
                <div class="cfo-followup-form-inner">
                    <div class="cfo-followup-type-grid">
                        {% for val, label in {chiamata: 'Chiamata', email: 'Email', sms: 'SMS', riunione: 'Riunione', nota: 'Nota'} %}
                        <label class="cfo-type-option">
                            <input type="radio" name="fu_type" value="{{ val }}" {% if val == 'nota' %}checked{% endif %}>
                            <span>{{ label }}</span>
                        </label>
                        {% endfor %}
                    </div>
                    <div class="cfo-followup-form-row">
                        <div class="cfo-field">
                            <div class="cfo-field-wrapper">
                                <label>Data</label>
                                <input type="date" id="fu_date" value="{{ "now"|date("Y-m-d") }}">
                            </div>
                        </div>
                        <div class="cfo-field cfo-field-grow">
                            <div class="cfo-field-wrapper">
                                <label>Nota</label>
                                <textarea id="fu_note" rows="2" placeholder="Descrivi l'attività..."></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="cfo-followup-form-actions">
                        <button type="button" class="cfo-btn-secondary" id="cancelFollowup">Annulla</button>
                        <button type="button" class="cfo-btn-primary" id="saveFollowup" data-offer-id="{{ offerId }}">Salva</button>
                    </div>
                </div>
            </div>

            {# Log list #}
            <div class="cfo-followup-list" id="followupList" style="margin-top:14px">
                {% if followups is empty %}
                <div class="cfo-followup-empty" id="followupEmpty">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Nessuna attività registrata
                </div>
                {% else %}
                {% for fu in followups %}
                <div class="cfo-followup-item" data-fu-id="{{ fu.id }}">
                    <div class="cfo-followup-item-icon cfo-futype-{{ fu.type }}">
                        {% if fu.type == 'chiamata' %}<svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .91h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                        {% elseif fu.type == 'email' %}<svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        {% elseif fu.type == 'sms' %}<svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                        {% elseif fu.type == 'riunione' %}<svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                        {% else %}<svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>{% endif %}
                    </div>
                    <div class="cfo-followup-item-body">
                        <div class="cfo-followup-item-meta">
                            <span class="cfo-followup-item-type">{{ fu.type|capitalize }}</span>
                            <span class="cfo-followup-item-date">{{ fu.followup_date|date('d/m/Y') }}</span>
                            <span class="cfo-followup-item-author">{{ fu.creator_name }}</span>
                        </div>
                        <p class="cfo-followup-item-note">{{ fu.note }}</p>
                    </div>
                    <button type="button" class="cfo-followup-delete" data-fu-id="{{ fu.id }}" data-offer-id="{{ offerId }}" title="Elimina">
                        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                </div>
                {% endfor %}
                {% endif %}
            </div>
        </div>

    </div>{# /cos-left #}

    {# ── Right column: PDF ── #}
    <div class="cos-right">
        <div class="cos-pdf-wrapper">
            <div class="cos-pdf-toolbar">
                <span class="cos-pdf-label">
                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Anteprima PDF
                </span>
                <a href="/offers/{{ offerId }}/pdf" target="_blank" class="cos-pdf-open">
                    <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Apri in nuova scheda
                </a>
            </div>
            <iframe class="cos-pdf-iframe" src="/offers/{{ offerId }}/pdf" title="Anteprima PDF"></iframe>
        </div>
    </div>

</div>{# /cos-grid #}

</div>{# /cos-page #}
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/offers/offer_show.js"></script>
{% endblock %}
