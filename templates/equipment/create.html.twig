{% extends 'layout/base.html.twig' %}

{% block content %}
<div class="intro-y box py-10 sm:py-20 mt-5">

    <div class="px-5 sm:px-20">
        <div class="font-medium text-center text-lg">
            {{ editing ? "Modifica Mezzo di Sollevamento" : "Nuovo Mezzo di Sollevamento" }}
        </div>
        <div class="text-slate-500 text-center mt-2">
            {{ editing ? "Stai modificando un mezzo esistente" : "Inserisci la descrizione e il costo giornaliero" }}
        </div>
    </div>

    {% if successMessage is not empty %}
        <div class="px-5 sm:px-20 mt-6">
            <div style="background-color: #d1fae5; color: #065f46; padding: 12px; border-radius: 6px;">
                {{ successMessage }}
            </div>
        </div>
    {% endif %}

    <!-- FORM -->
    <form method="POST" class="px-5 sm:px-20 mt-6">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {% if editing %}
            <input type="hidden" name="update_item" value="1">
            <input type="hidden" name="edit_id" value="{{ editData.id }}">
        {% else %}
            <input type="hidden" name="create_item" value="1">
        {% endif %}

        <div class="grid grid-cols-12 gap-4">
            <div class="intro-y col-span-12 sm:col-span-6">
                <label class="form-label">Descrizione</label>
                <input type="text" name="descrizione"
                       value="{{ editing ? editData.descrizione : '' }}"
                       class="form-control" required>
            </div>

            <div class="intro-y col-span-12 sm:col-span-6">
                <label class="form-label">Costo Giornaliero (€)</label>
                <input type="number" name="costo_giornaliero" step="0.01" min="0"
                       value="{{ editing ? editData.costo_giornaliero : '' }}"
                       class="form-control" required>
            </div>
        </div>

        <div class="intro-y col-span-12 flex justify-end mt-6 gap-3">
            {% if editing %}
                <a href="/equipment/manage" class="btn btn-secondary w-24">Annulla</a>
                <button type="submit" class="btn btn-primary w-24">Aggiorna</button>
            {% else %}
                <button type="submit" class="btn btn-primary w-24">Salva</button>
            {% endif %}
        </div>

    </form>
</div>

<!-- SEARCH + ACTION BAR -->
<div class="intro-y col-span-12 flex flex-wrap xl:flex-nowrap items-center mt-10">

    <input id="search-mezzo"
           type="text"
           placeholder="Cerca mezzo..."
           class="form-control w-64 shadow-md mr-2 mt-2 xl:mt-0" />


</div>

<!-- TABLE CONTAINER -->
<div class="intro-y col-span-12 overflow-auto mt-5">
    <table class="table table-report -mt-2" id="mezzi-table">
        <thead>
        <tr>
            <th class="whitespace-nowrap">Descrizione</th>
            <th class="text-center whitespace-nowrap">Costo Giornaliero (€)</th>
            <th class="text-center whitespace-nowrap">Azioni</th>
        </tr>
        </thead>

        <tbody>
        {% for m in listaMezzi %}
            <tr class="intro-x">
                <td class="!py-3.5">
                    <div class="flex items-center">
                        <div class="ml-4">
                            <div class="font-medium whitespace-nowrap">
                                {{ m.descrizione }}
                            </div>
                        </div>
                    </div>
                </td>

                <td class="text-center">
                    {{ m.costo_giornaliero|number_format(2, ',', '.') }}
                </td>

                <td class="table-report__action w-56">
                    <div class="flex justify-center items-center">

                        <!-- EDIT -->
                        {# TODO: 'edit_id' is a GET param — controller reads $_GET['edit_id'] and passes `editing`/`editData` #}
                        <a class="flex items-center mr-3"
                           href="?edit_id={{ m.id }}">
                            <i data-lucide="check-square" class="w-4 h-4 mr-1"></i>
                            Modifica
                        </a>

                        <!-- DELETE -->
                        <button type="button"
                                class="flex items-center text-danger"
                                data-delete-id="{{ m.id }}"
                                data-tw-toggle="modal"
                                data-tw-target="#deleteModal">
                            <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i>
                            Elimina
                        </button>

                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>

    </table>
</div>

<div id="deleteModal" class="modal" tabindex="-1">
    <div class="modal-dialog">
        <form method="POST" class="modal-content">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <input type="hidden" name="delete_item" value="1">
            <input type="hidden" id="delete_id_input" name="delete_id">

            <div class="modal-body p-5 text-center">
                <i data-lucide="x-circle" class="w-16 h-16 text-danger mx-auto"></i>
                <h3 class="text-3xl mt-5">Sei sicuro?</h3>
                <p class="text-slate-500 mt-2">Questa operazione è irreversibile.</p>
            </div>

            <div class="modal-footer px-5 pb-8 text-center">
                <button type="button" data-tw-dismiss="modal" class="btn btn-outline-secondary w-24 mr-1">
                    Annulla
                </button>
                <button type="submit" class="btn btn-danger w-24">
                    Elimina
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/assets/js/views/equipment/add_lifting_equipment.js"></script>
{% endblock %}
