{% extends "layout/base.html.twig" %}

{% block head %}
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.css" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/views/bookings/edit_booking.css">
{% endblock %}

{% block content %}
{% set type = booking.type %}

{% if errors is not empty %}
    <div style="background:linear-gradient(135deg,#fee2e2,#fecaca);color:#991b1b;border-radius:12px;padding:14px 20px;font-size:13px;font-weight:600;margin-top:16px;border:1px solid #fca5a5;">
        {% for e in errors %}<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg> {{ e }}</div>{% endfor %}
    </div>
{% endif %}

<div class="bk-page">

    <div class="bk-header">
        <div class="bk-header-left">
            <div class="bk-header-icon {{ type == 'hotel' ? 'hotel' : '' }}">
                {% if type == 'hotel' %}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M3 21h18M3 7v14M21 7v14M6 11h12M6 7h12M9 3h6"/></svg>
                {% else %}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M18 8a6 6 0 01-6 6M6 8a6 6 0 006 6M12 2v2M3 20h18"/></svg>
                {% endif %}
            </div>
            <div>
                <div class="bk-header-title">Modifica — {{ booking.struttura_nome }}</div>
                <div class="bk-header-sub">Aggiorna struttura, periodi e fatture</div>
            </div>
        </div>
        <a href="/bookings" class="bk-btn-cancel">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Torna alla lista
        </a>
    </div>

    <form method="POST" id="booking-form"
          data-booking-id="{{ bookingId }}"
          data-struttura-id="{{ booking.struttura_id }}"
          data-struttura-nome="{{ booking.struttura_nome }}"
          data-period-index="{{ periods|length }}">

        <div style="margin-bottom:24px;">
            <div class="bk-type-toggle">
                <button type="button" class="bk-type-btn restaurant {{ type == 'restaurant' ? 'active' : '' }}" data-bk-type="restaurant">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 01-6 6M6 8a6 6 0 006 6M12 2v2M3 20h18"/></svg>
                    Ristorante
                </button>
                <button type="button" class="bk-type-btn hotel {{ type == 'hotel' ? 'active' : '' }}" data-bk-type="hotel">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M3 7v14M21 7v14M6 11h12"/></svg>
                    Hotel
                </button>
            </div>
            <input type="hidden" name="type" id="type-input" value="{{ type }}">
        </div>

        <div class="bk-layout">

            <!-- LEFT -->
            <div>
                <div class="bk-card">
                    <div class="bk-card-header">
                        <div class="bk-card-header-icon" style="background:linear-gradient(135deg,#fef3c7,#fde68a);">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2.5"><path d="M3 21h18M3 7l9-4 9 4M4 7v14M20 7v14M8 21V11m8 10V11"/></svg>
                        </div>
                        <div><div class="bk-card-header-title">Struttura</div><div class="bk-card-header-sub">Cerca esistente o inserisci nuova</div></div>
                    </div>
                    <div class="bk-card-body">
                        <input type="hidden" name="struttura_id" id="struttura_id" value="{{ booking.struttura_id }}">
                        <input type="hidden" name="struttura_nome" id="struttura_nome" value="{{ booking.struttura_nome }}">

                        <div class="bk-mode-toggle">
                            <button type="button" class="bk-mode-btn active" id="mode-search-btn" data-bk-mode="search">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                                Cerca esistente
                            </button>
                            <button type="button" class="bk-mode-btn" id="mode-new-btn" data-bk-mode="new">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Crea nuova
                            </button>
                        </div>

                        <div id="struttura-mode-search">
                            <div class="bk-field">
                                <label class="bk-label">Cerca struttura</label>
                                <select id="struttura-search-select"><option value="">Digita per cercare...</option></select>
                            </div>
                        </div>

                        <div id="struttura-mode-new" style="display:none;">
                            <div class="bk-field">
                                <label class="bk-label">Nome struttura *</label>
                                <input type="text" id="struttura_nome_input" class="bk-input" placeholder="Es. Hotel Cristallo"
                                       value="">
                            </div>
                        </div>

                        <div id="struttura-details">
                            <div class="bk-struttura-details">
                                <div class="bk-field"><label class="bk-label">Telefono</label><input type="text" name="struttura_telefono" id="struttura_telefono" class="bk-input" placeholder="+39 0123 456789" value="{{ booking.struttura_telefono ?? '' }}"></div>
                                <div class="bk-field"><label class="bk-label">Indirizzo</label><input type="text" name="struttura_indirizzo" id="struttura_indirizzo" class="bk-input" placeholder="Via Roma 1" value="{{ booking.struttura_indirizzo ?? '' }}"></div>
                                <div class="bk-row-3">
                                    <div class="bk-field"><label class="bk-label">Città</label><input type="text" name="struttura_citta" id="struttura_citta" class="bk-input" placeholder="Milano" value="{{ booking.struttura_citta ?? '' }}"></div>
                                    <div class="bk-field"><label class="bk-label">Prov.</label><input type="text" name="struttura_provincia" id="struttura_provincia" class="bk-input" placeholder="MI" maxlength="10" value="{{ booking.struttura_provincia ?? '' }}"></div>
                                    <div class="bk-field"><label class="bk-label">Paese</label><input type="text" name="struttura_country" id="struttura_country" class="bk-input" value="{{ booking.struttura_country ?? 'Italia' }}"></div>
                                </div>
                                <div class="bk-field"><label class="bk-label">Ragione sociale</label><input type="text" name="struttura_ragione_sociale" id="struttura_ragione_sociale" class="bk-input" placeholder="Ragione sociale (opzionale)" value="{{ booking.struttura_ragione_sociale ?? '' }}"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bk-card">
                    <div class="bk-card-header">
                        <div class="bk-card-header-icon" style="background:linear-gradient(135deg,#dbeafe,#bfdbfe);">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                        </div>
                        <div><div class="bk-card-header-title">Dettagli prenotazione</div><div class="bk-card-header-sub">Cantiere, capo squadra e servizio</div></div>
                    </div>
                    <div class="bk-card-body">
                        <div class="bk-field"><label class="bk-label">Cantiere</label>
                            <select name="worksite_id" id="worksite-select">
                                <option value="">-- Nessuno --</option>
                                {% for ws in worksites %}
                                    <option value="{{ ws.id }}" {{ booking.worksite_id == ws.id ? 'selected' : '' }}>{{ ws.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="bk-field"><label class="bk-label">Capo squadra</label>
                            <select name="capo_squadra_id" id="capo-squadra-select">
                                <option value="">-- Nessuno --</option>
                                {% for w in workers %}
                                    <option value="{{ w.id }}" {{ booking.capo_squadra_id == w.id ? 'selected' : '' }}>{{ w.nome }} ({{ w.company }})</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div id="restaurant-fields" class="bk-field" style="display:{{ type == 'restaurant' ? 'block' : 'none' }};">
                            <label class="bk-label">Pasti inclusi</label>
                            <div class="bk-check-group">
                                <label class="bk-check-label"><input type="checkbox" name="pranzo" value="1" {{ booking.pranzo is not empty ? 'checked' : '' }}> Pranzo</label>
                                <label class="bk-check-label"><input type="checkbox" name="cena" value="1" {{ booking.cena is not empty ? 'checked' : '' }}> Cena</label>
                            </div>
                        </div>

                        <div id="hotel-fields" class="bk-field" style="display:{{ type == 'hotel' ? 'block' : 'none' }};">
                            <label class="bk-label">Regime</label>
                            <select name="regime" class="bk-select">
                                <option value="">-- Seleziona --</option>
                                <option value="PC" {{ (booking.regime ?? '') == 'PC' ? 'selected' : '' }}>Pensione Completa</option>
                                <option value="MP" {{ (booking.regime ?? '') == 'MP' ? 'selected' : '' }}>Mezza Pensione</option>
                                <option value="BB" {{ (booking.regime ?? '') == 'BB' ? 'selected' : '' }}>B&B</option>
                                <option value="solo_dormire" {{ (booking.regime ?? '') == 'solo_dormire' ? 'selected' : '' }}>Solo dormire</option>
                            </select>
                        </div>

                        <div class="bk-field"><label class="bk-label">Note</label><textarea name="note" class="bk-textarea" placeholder="Indicazioni particolari...">{{ booking.note ?? '' }}</textarea></div>

                        {% if consorziate is not empty %}
                        <div class="bk-field" style="border-top:1px solid #f1f5f9; padding-top:14px; margin-top:4px;">
                            <label class="bk-check-label" style="font-weight:600; font-size:13px; color:#1e293b; gap:8px; cursor:pointer;">
                                <input type="checkbox" name="a_carico_consorziata" value="1"
                                       id="chk-consorziata"
                                       {{ booking.a_carico_consorziata ? 'checked' : '' }}>
                                A carico della consorziata
                            </label>
                            <div id="consorziata-select-wrap" style="margin-top:10px; display:{{ booking.a_carico_consorziata ? 'block' : 'none' }};">
                                <label class="bk-label">Consorziata</label>
                                <select name="consorziata_id" class="bk-select">
                                    <option value="">-- Seleziona consorziata --</option>
                                    {% for c in consorziate %}
                                        <option value="{{ c.id }}" {{ booking.consorziata_id == c.id ? 'selected' : '' }}>{{ c.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- RIGHT -->
            <div>
                <div class="bk-card">
                    <div class="bk-card-header">
                        <div class="bk-card-header-icon" style="background:linear-gradient(135deg,#dcfce7,#bbf7d0);">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#15803d" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </div>
                        <div><div class="bk-card-header-title">Periodi</div><div class="bk-card-header-sub">Definisci persone, prezzi e date per ogni fase</div></div>
                    </div>
                    <div class="bk-card-body">
                        <div id="periods-container">
                            {% for i, period in periods %}
                            <div class="bk-period-row" data-index="{{ i }}" data-period-id="{{ period.id ?? '' }}">
                                <input type="hidden" name="periods[{{ i }}][id]" value="{{ period.id ?? '' }}">
                                <div class="bk-period-field" style="width:120px;"><span class="bk-period-label">Dal</span><input type="date" name="periods[{{ i }}][data_dal]" class="bk-period-input period-dal" value="{{ period.data_dal ?? '' }}"></div>
                                <div class="bk-period-field" style="width:120px;"><span class="bk-period-label">Al</span><input type="date" name="periods[{{ i }}][data_al]" class="bk-period-input period-al" value="{{ period.data_al ?? '' }}"></div>
                                <div class="bk-period-field" style="width:85px;"><span class="bk-period-label">Persone</span><input type="number" name="periods[{{ i }}][n_persone]" class="bk-period-input period-persone" min="1" value="{{ period.n_persone ?? '' }}"></div>
                                <div class="bk-period-field" style="width:100px;"><span class="bk-period-label">€ / persona</span><input type="number" name="periods[{{ i }}][prezzo_persona]" class="bk-period-input period-prezzo" step="0.01" min="0" value="{{ period.prezzo_persona ?? '' }}" required></div>
                                <div class="bk-period-field grow"><span class="bk-period-label">Nota</span><input type="text" name="periods[{{ i }}][note]" class="bk-period-input" value="{{ period.note ?? '' }}"></div>
                                <span class="bk-period-subtotal period-subtotal" style="display:none;"></span>
                                <button type="button" class="bk-period-remove" title="Rimuovi"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                            </div>
                            {% endfor %}
                        </div>
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:14px;flex-wrap:wrap;gap:10px;">
                            <button type="button" class="bk-add-btn" data-bk-action="add-period"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Aggiungi periodo</button>
                            <div class="bk-grand-total" id="grand-total"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg> Totale: <span id="grand-total-value">€0</span></div>
                        </div>
                    </div>
                </div>

                <!-- ECCEZIONI PASTO -->
                <div class="bk-card">
                    <div class="bk-card-header">
                        <div class="bk-card-header-icon" style="background:linear-gradient(135deg,#fce7f3,#fbcfe8);">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#be185d" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        </div>
                        <div>
                            <div class="bk-card-header-title">Eccezioni pasto</div>
                            <div class="bk-card-header-sub">Regole settimanali o date specifiche con pasti diversi</div>
                        </div>
                    </div>
                    <div class="bk-card-body" style="padding:0;">

                        {# ── Existing overrides ── #}
                        <div id="overrides-list">
                        {% if overrides is not empty %}
                            {% set dayNames = {1:'Lunedì',2:'Martedì',3:'Mercoledì',4:'Giovedì',5:'Venerdì',6:'Sabato',7:'Domenica'} %}
                            {% set regimeLabels = {'PC':'P. Completa','MP':'M. Pensione','BB':'B&B','solo_dormire':'Solo dormire'} %}
                            {% for o in overrides %}
                            <div class="bk-override-row"
                                 data-override-id="{{ o.id }}"
                                 data-ov-type="{{ o.override_type }}"
                                 data-weekday="{{ o.weekday ?? '' }}"
                                 data-date="{{ o.data ?? '' }}"
                                 data-skip-day="{{ o.skip_day ? '1' : '0' }}"
                                 data-period-id="{{ o.period_id ?? '' }}">
                                <div class="bk-override-when {{ o.override_type == 'weekday' ? 'weekly' : 'specific' }}">
                                    {% if o.override_type == 'weekday' %}
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
                                        Ogni {{ dayNames[o.weekday] ?? '?' }}
                                    {% else %}
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                        {{ o.data|date('d/m/Y') }}
                                    {% endif %}
                                </div>
                                <div class="bk-override-tags">
                                    {% if o.period_dal and o.period_al %}
                                        <span class="bk-otag bk-otag-period">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                            {{ o.period_dal|date('d/m') }} → {{ o.period_al|date('d/m') }}
                                        </span>
                                    {% endif %}
                                    {% if o.skip_day %}
                                        <span class="bk-otag skip">Nessun pasto</span>
                                    {% elseif type == 'restaurant' %}
                                        {% if o.pranzo is not null or o.cena is not null %}
                                            {% if o.pranzo %}<span class="bk-otag pranzo">Pranzo</span>{% endif %}
                                            {% if o.cena   %}<span class="bk-otag cena">Cena</span>{% endif %}
                                            {% if not o.pranzo and not o.cena %}<span class="bk-otag skip">Nessun pasto</span>{% endif %}
                                        {% else %}
                                            <span class="bk-otag default">Default</span>
                                        {% endif %}
                                    {% elseif type == 'hotel' %}
                                        {% if o.regime %}
                                            <span class="bk-otag regime">{{ regimeLabels[o.regime] ?? o.regime }}</span>
                                        {% else %}
                                            <span class="bk-otag default">Default</span>
                                        {% endif %}
                                    {% endif %}
                                    {% if o.note %}<span class="bk-override-note">{{ o.note }}</span>{% endif %}
                                </div>
                                <button type="button" class="bk-override-remove" title="Rimuovi regola"
                                        data-bk-delete-override="{{ o.id }}">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                            {% endfor %}
                        {% else %}
                            <div class="bk-override-empty" id="no-overrides-msg">
                                Nessuna eccezione — tutti i giorni seguono le impostazioni base.
                            </div>
                        {% endif %}
                        </div>

                        {# ── Add override form ── #}
                        <div style="padding:0 22px 22px;">
                            <div class="bk-override-form" id="add-override-form" style="display:none;">
                                <div class="bk-override-form-title">Nuova regola</div>

                                {# Period selector — only shows already-saved periods #}
                                {% set savedPeriods = periods|filter(p => p.id is defined and p.id) %}
                                {% if savedPeriods|length > 1 %}
                                <div class="bk-field" style="margin-bottom:14px;">
                                    <label class="bk-label">Periodo</label>
                                    <select id="ov-period-id" class="bk-select">
                                        <option value="">— Tutti i periodi —</option>
                                        {% for p in savedPeriods %}
                                        <option value="{{ p.id }}">
                                            Periodo {{ loop.index }}{% if p.data_dal %}: {{ p.data_dal|date('d/m/Y') }}{% endif %}{% if p.data_al %} → {{ p.data_al|date('d/m/Y') }}{% endif %}{% if p.note %} ({{ p.note }}){% endif %}
                                        </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                {% else %}
                                    {# single period — silently pre-select it #}
                                    <input type="hidden" id="ov-period-id" value="{{ savedPeriods|first ? savedPeriods|first.id : '' }}">
                                {% endif %}

                                <div class="bk-row" style="margin-bottom:14px;">
                                    <div>
                                        <div class="bk-label">Tipo eccezione</div>
                                        <div class="bk-override-type-toggle">
                                            <label class="bk-override-type-opt">
                                                <input type="radio" name="_ov_type" value="weekday" checked data-bk-action="override-type">
                                                <span>Ogni settimana</span>
                                            </label>
                                            <label class="bk-override-type-opt">
                                                <input type="radio" name="_ov_type" value="date" data-bk-action="override-type">
                                                <span>Data specifica</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <div id="ov-weekday-field" class="bk-field" style="margin-bottom:14px;">
                                    <label class="bk-label">Giorno della settimana</label>
                                    <select id="ov-weekday" class="bk-select">
                                        <option value="1">Lunedì</option>
                                        <option value="2">Martedì</option>
                                        <option value="3">Mercoledì</option>
                                        <option value="4">Giovedì</option>
                                        <option value="5" selected>Venerdì</option>
                                        <option value="6">Sabato</option>
                                        <option value="7">Domenica</option>
                                    </select>
                                </div>
                                <div id="ov-date-field" class="bk-field" style="display:none;margin-bottom:14px;">
                                    <label class="bk-label">Data specifica</label>
                                    <input type="date" id="ov-data" class="bk-input">
                                </div>

                                <div class="bk-field" style="margin-bottom:14px;">
                                    <label class="bk-check-label" style="font-size:13px;">
                                        <input type="checkbox" id="ov-skip-day" data-bk-action="override-skip">
                                        Salta giorno — nessun pasto / nessun servizio
                                    </label>
                                </div>

                                <div id="ov-meal-fields" style="margin-bottom:14px;">
                                    <div id="ov-restaurant-meals" style="display:{{ type == 'restaurant' ? 'block' : 'none' }};">
                                        <label class="bk-label">Pasti inclusi in questo giorno</label>
                                        <div class="bk-check-group">
                                            <label class="bk-check-label"><input type="checkbox" id="ov-pranzo" checked> Pranzo</label>
                                            <label class="bk-check-label"><input type="checkbox" id="ov-cena"> Cena</label>
                                        </div>
                                    </div>
                                    <div id="ov-hotel-regime" style="display:{{ type == 'hotel' ? 'block' : 'none' }};">
                                        <label class="bk-label">Regime in questo giorno</label>
                                        <select id="ov-regime" class="bk-select">
                                            <option value="">— Stesso regime base —</option>
                                            <option value="PC">Pensione Completa</option>
                                            <option value="MP">Mezza Pensione</option>
                                            <option value="BB">B&amp;B</option>
                                            <option value="solo_dormire">Solo dormire</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="bk-field" style="margin-bottom:16px;">
                                    <label class="bk-label">Nota (opzionale)</label>
                                    <input type="text" id="ov-note" class="bk-input" placeholder="Es. venerdì rientrano a casa">
                                </div>

                                <div style="display:flex;gap:8px;justify-content:flex-end;">
                                    <button type="button" class="bk-btn-cancel" data-bk-action="hide-override-form" style="padding:7px 16px;font-size:12px;">Annulla</button>
                                    <button type="button" class="bk-fattura-btn save" data-bk-action="submit-override" style="padding:7px 16px;font-size:12px;">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                        Aggiungi regola
                                    </button>
                                </div>
                            </div>
                            <button type="button" class="bk-add-btn" style="margin-top:14px;width:100%;justify-content:center;" data-bk-action="show-override-form">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Aggiungi regola
                            </button>
                        </div>
                    </div>
                </div>

                <!-- FATTURE -->
                <div class="bk-card">
                    <div class="bk-card-header">
                        <div class="bk-card-header-icon" style="background:linear-gradient(135deg,#fef3c7,#fde68a);">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                        </div>
                        <div><div class="bk-card-header-title">Fatture</div><div class="bk-card-header-sub">{{ fatture|length }} fattur{{ fatture|length == 1 ? 'a' : 'e' }} caricate</div></div>
                    </div>
                    <div class="bk-card-body" style="padding:0;">
                        <div id="fatture-list" style="padding:0;">
                            {% if fatture is empty %}
                                <div class="bk-fattura-empty" id="no-fatture-msg">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" style="margin:0 auto 8px;display:block;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                    Nessuna fattura caricata
                                </div>
                            {% endif %}
                            {% for f in fatture %}
                            <div class="bk-fattura-row" data-fattura-id="{{ f.id }}">
                                <div class="bk-fattura-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
                                <div class="bk-fattura-info">
                                    <div class="bk-fattura-numero">{{ f.numero ? f.numero : 'Senza numero' }}</div>
                                    <div class="bk-fattura-meta">
                                        {% if f.data_fattura %}<span>{{ f.data_fattura|date('d/m/Y') }}</span>{% endif %}
                                        {% if f.data_fattura and f.importo %}<span class="bk-fattura-meta-sep">·</span>{% endif %}
                                        {% if f.importo %}<span style="font-weight:600;color:#1e293b;">€{{ f.importo|number_format(2, ',', '.') }}</span>{% endif %}
                                        {% if f.note %}<span class="bk-fattura-meta-sep">·</span><span>{{ f.note }}</span>{% endif %}
                                    </div>
                                </div>
                                <div class="bk-fattura-actions">
                                    <button type="button"
                                            class="bk-fattura-btn bk-fattura-pagato {{ f.pagato ? 'is-paid' : '' }}"
                                            data-bk-toggle-pagato="{{ f.id }}"
                                            title="{{ f.pagato ? 'Segna come non pagata' : 'Segna come pagata' }}">
                                        {% if f.pagato %}
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Pagata
                                        {% else %}
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/></svg> Non pagata
                                        {% endif %}
                                    </button>
                                    {% if f.file_path %}
                                        <a href="/bookings/fattura/{{ f.id }}/serve" target="_blank" class="bk-fattura-btn download"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Scarica</a>
                                    {% endif %}
                                    <button type="button" class="bk-fattura-btn delete" data-bk-delete-fattura="{{ f.id }}"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg> Elimina</button>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        <div style="padding:0 22px 22px;">
                            <div class="bk-fattura-form" id="add-fattura-form" style="display:none;">
                                <div style="font-size:12px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.04em;margin-bottom:12px;">Nuova fattura</div>
                                <div class="bk-row" style="margin-bottom:12px;"><div class="bk-field"><label class="bk-label">N. Fattura</label><input type="text" id="new-fattura-numero" class="bk-input" placeholder="FT-2026/001"></div><div class="bk-field"><label class="bk-label">Data</label><input type="date" id="new-fattura-data" class="bk-input"></div></div>
                                <div class="bk-row" style="margin-bottom:12px;"><div class="bk-field"><label class="bk-label">Importo €</label><input type="number" id="new-fattura-importo" class="bk-input" step="0.01" min="0" placeholder="0.00"></div><div class="bk-field"><label class="bk-label">Nota</label><input type="text" id="new-fattura-note" class="bk-input" placeholder="Note..."></div></div>
                                <div class="bk-field" style="margin-bottom:14px;"><label class="bk-label">File (PDF, immagine...)</label><input type="file" id="new-fattura-file" class="bk-input" style="padding-top:8px;height:auto;"></div>
                                <div style="display:flex;gap:8px;justify-content:flex-end;">
                                    <button type="button" class="bk-btn-cancel" data-bk-action="hide-fattura-form" style="padding:7px 16px;font-size:12px;">Annulla</button>
                                    <button type="button" class="bk-fattura-btn save" data-bk-action="submit-fattura" style="padding:7px 16px;font-size:12px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Salva fattura</button>
                                </div>
                            </div>
                            <button type="button" class="bk-add-btn" style="margin-top:14px;width:100%;justify-content:center;" data-bk-action="show-fattura-form"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Aggiungi fattura</button>
                        </div>
                    </div>
                </div>

                <div class="bk-submit-bar">
                    <a href="/bookings" class="bk-btn-cancel">Annulla</a>
                    <button type="submit" class="bk-btn-submit {{ type == 'hotel' ? 'hotel' : '' }}" id="submit-btn"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg> Salva Modifiche</button>
                </div>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
<script src="/assets/js/views/bookings/edit_booking.js"></script>
{% endblock %}
